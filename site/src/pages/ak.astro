        cyan
      </div>
      <div class="ak-layer ak-layer-blue ak-layer-blue-500 hover:ak-state-10">
        blue
      </div>
      <div
        class="ak-layer ak-layer-contrast-30 ak-layer-canvas hover:ak-state-10"
      >
        canvas contrast
      </div>
      <div
        class="ak-layer ak-layer-magenta ak-layer-blue-500 hover:ak-state-10"
      >
        magenta
      </div>
    </div>
    <div class="[--contrast:85]">
      <div class="flex flex-wrap gap-2 m- *:p-4">
        <div class="ak-layer ak-layer-black hover:ak-state-10 ak-layer-min-20">
