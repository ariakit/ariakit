              >
                overflow last
              </div>
            </div>
          </div>
        </div>

        <div class="grid gap-3">
          <div class="text-sm font-medium opacity-70">
            Row axis and manual edges
          </div>
          <div
            class="grid gap-4 ak-layer ak-layer-white ak-frame ak-frame-rounded-3xl ak-frame-p-4 ak-frame-border-1 ak-edge-20"
          >
            <div
              class="flex ak-layer ak-layer-10 ak-frame ak-frame-rounded-2xl ak-frame-p-3 overflow-auto"
            >
              <div
                class="min-w-36 ak-layer ak-layer-primary ak-frame ak-frame-row ak-frame-cover ak-frame-start ak-frame-rounded-xl ak-frame-p-3"
              >
                row start
