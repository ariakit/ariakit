import ContentAdmonition from "#app/components/content-admonition.astro";
import ContentCodeBlock from "#app/components/content-code-block.astro";
import ContentDisclosure from "#app/components/content-disclosure.astro";
import ContentHeading from "#app/components/content-heading.astro";
import ContentLink from "#app/components/content-link.astro";
import ContentListItem from "#app/components/content-list-item.astro";
import ContentList from "#app/components/content-list.astro";
import ContentParagraph from "#app/components/content-paragraph.astro";
import ContentSeparator from "#app/components/content-separator.astro";
import { markdownToHtml } from "#app/lib/content.ts";
import { Markup } from "astro-remote";

interface Props {
  content: string;
}

const { content } = Astro.props;

const html = await markdownToHtml(content);
// Temporary Astro 6 workaround: importing this content-components map from a
// shared `.astro` module breaks the build with a missing default export error.
const components = {
  a: ContentLink,
  p: ContentParagraph,
  pre: ContentCodeBlock,
  h1: ContentHeading,
  h2: ContentHeading,
  h3: ContentHeading,
  h4: ContentHeading,
  h5: ContentHeading,
  h6: ContentHeading,
  ul: ContentList,
  ol: ContentList,
  li: ContentListItem,
  admonition: ContentAdmonition,
  hr: ContentSeparator,
  details: ContentDisclosure,
};
---

<Markup content={html} components={components} />
