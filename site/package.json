{
  "name": "site",
  "type": "module",
  "version": "0.0.1",
  "license": "See license.md",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "dev-lite": "cross-env DISABLE_REFERENCE_LINKS=true pnpm run dev",
    "listen-stripe": "stripe listen --forward-to http://localhost:4321/api/stripe-webhook",
    "dev-stripe": "concurrently -k -r 'pnpm:dev' 'pnpm:listen-*'",
    "dev-stripe-lite": "concurrently -k -r 'pnpm:dev-lite' 'pnpm:listen-*'",
    "tsc": "astro check && tsc -b src",
    "build": "astro build",
    "build-lite": "cross-env DISABLE_REFERENCE_LINKS=true pnpm run build",
    "build-min": "cross-env DISABLE_SYNTAX_HIGHLIGHTING=true pnpm run build-lite",
    "preview": "wrangler dev",
    "preview-lite": "cross-env DISABLE_REFERENCE_LINKS=true pnpm run preview",
    "preview-stripe": "concurrently -k -r 'pnpm:preview' 'pnpm:listen-*'",
    "preview-stripe-lite": "concurrently -k -r 'pnpm:preview-lite' 'pnpm:listen-*'",
    "test": "playwright test",
    "test-chrome": "playwright test --project=chrome",
    "test-firefox": "playwright test --project=firefox",
    "test-safari": "playwright test --project=safari",
    "test-ios": "playwright test --project=ios",
    "test-android": "playwright test --project=android",
    "test-chrome-headed": "playwright test --project=chrome --headed",
    "test-firefox-headed": "playwright test --project=firefox --headed",
    "test-safari-headed": "playwright test --project=safari --headed",
    "test-ios-headed": "playwright test --project=ios --headed",
    "test-android-headed": "playwright test --project=android --headed",
    "test-visual": "cross-env VISUAL_TEST=true playwright test",
    "test-visual-chrome": "cross-env VISUAL_TEST=true playwright test --project=chrome",
    "test-visual-firefox": "cross-env VISUAL_TEST=true playwright test --project=firefox",
    "test-visual-safari": "cross-env VISUAL_TEST=true playwright test --project=safari",
    "test-visual-ios": "cross-env VISUAL_TEST=true playwright test --project=ios",
    "test-visual-android": "cross-env VISUAL_TEST=true playwright test --project=android",
    "og-image-clean": "rimraf public/og-image",
    "og-image-generate": "pnpm run og-image-clean && node src/pages/og-image/_generate-images.ts",
    "build-styles": "node src/lib/build-styles.ts"
  },
  "imports": {
    "#app/*": "./src/*"
  },
  "exports": {
    "./*": "./src/examples/_lib/*"
  },
  "dependencies": {
    "@astrojs/check": "0.9.7",
    "@astrojs/cloudflare": "12.6.13",
    "@astrojs/markdown-remark": "6.3.11",
    "@astrojs/mdx": "4.3.14",
    "@astrojs/react": "4.4.2",
    "@astrojs/solid-js": "5.1.3",
    "@clerk/astro": "2.17.8",
    "@fontsource-variable/inter": "5.2.8",
    "@shikijs/langs": "4.0.2",
    "@shikijs/themes": "4.0.2",
    "@stackblitz/sdk": "1.11.0",
    "@tanstack/react-query": "5.90.21",
    "@stripe/stripe-js": "7.9.0",
    "@types/pluralize": "0.0.33",
    "astro": "5.18.1",
    "astro-remote": "0.3.4",
    "canvas-confetti": "1.9.4",
    "date-fns": "4.1.0",
    "diff": "8.0.3",
    "hast-util-to-text": "4.0.2",
    "html-entities": "2.6.0",
    "import-meta-resolve": "4.2.0",
    "kleur": "4.1.5",
    "lucide-react": "0.577.0",
    "parse-numeric-range": "1.3.0",
    "playwright": "1.58.2",
    "pluralize": "8.0.0",
    "prettier": "3.8.1",
    "react-aria-components": "1.16.0",
    "read-pkg-up": "11.0.0",
    "rehype-autolink-headings": "7.1.0",
    "rehype-parse": "9.0.1",
    "shadcn": "4.0.8",
    "shiki": "4.0.2",
    "stripe": "18.5.0",
    "tailwindcss": "4.2.1",
    "ts-morph": "27.0.2",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0",
    "use-local-storage-state": "19.5.0",
    "vfile": "6.0.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/hast": "3.0.4"
  }
}
