{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 80,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": true,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "sortImports": {},
  "ignorePatterns": [
    "**/node_modules",
    "**/package.json",
    "**/dist",
    "**/build",
    "**/.next",
    "**/.pages",
    "**/.astro",
    "**/.types",
    "**/*.astro",
    "**/*.css",
    "site/src/styles/styles.json"
  ]
}
