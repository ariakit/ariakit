{
  "compilerOptions": {
    "target": "es2018",
    "lib": ["dom", "dom.iterable", "es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "customConditions": ["ariakit-source"],
    "allowImportingTsExtensions": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "dist"]
}
