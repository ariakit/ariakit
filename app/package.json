{
  "name": "app",
  "version": "0.0.1",
  "private": true,
  "license": "See license.md",
  "type": "module",
  "imports": {
    "#app/*": "./src/*"
  },
  "exports": {
    "./*": "./src/examples/_lib/*"
  },
  "scripts": {
    "dev": "astro dev",
    "dev-lite": "cross-env DISABLE_REFERENCE_LINKS=true pnpm run dev",
    "listen-stripe": "stripe listen --forward-to http://localhost:4321/api/stripe-webhook",
    "dev-stripe": "concurrently -k -r 'pnpm:dev' 'pnpm:listen-*'",
    "dev-stripe-lite": "concurrently -k -r 'pnpm:dev-lite' 'pnpm:listen-*'",
    "wrangler-types": "wrangler types",
    "check": "pnpm run wrangler-types && cross-env APP_VITE_CACHE_DIR=node_modules/.vite-check astro check",
    "build": "astro build",
    "build-lite": "cross-env DISABLE_REFERENCE_LINKS=true pnpm run build",
    "build-min": "cross-env DISABLE_SYNTAX_HIGHLIGHTING=true pnpm run build-lite",
    "preview": "astro preview",
    "preview-lite": "cross-env DISABLE_REFERENCE_LINKS=true pnpm run preview",
    "preview-stripe": "concurrently -k -r 'pnpm:preview' 'pnpm:listen-*'",
    "preview-stripe-lite": "concurrently -k -r 'pnpm:preview-lite' 'pnpm:listen-*'",
    "test": "playwright test",
    "test-chrome": "pnpm run test --project=chrome",
    "test-firefox": "pnpm run test --project=firefox",
    "test-safari": "pnpm run test --project=safari",
    "test-ios": "pnpm run test --project=ios",
    "test-android": "pnpm run test --project=android",
    "test-chrome-headed": "pnpm run test --project=chrome --headed",
    "test-firefox-headed": "pnpm run test --project=firefox --headed",
    "test-safari-headed": "pnpm run test --project=safari --headed",
    "test-ios-headed": "pnpm run test --project=ios --headed",
    "test-android-headed": "pnpm run test --project=android --headed",
    "test-visual": "cross-env VISUAL_TEST=true pnpm run test",
    "test-visual-chrome": "cross-env VISUAL_TEST=true pnpm run test --project=chrome",
    "test-visual-firefox": "cross-env VISUAL_TEST=true pnpm run test --project=firefox",
    "test-visual-safari": "cross-env VISUAL_TEST=true pnpm run test --project=safari",
    "test-visual-ios": "cross-env VISUAL_TEST=true pnpm run test --project=ios",
    "test-visual-android": "cross-env VISUAL_TEST=true pnpm run test --project=android",
    "test-perf": "cross-env PERF_TEST=true pnpm run test",
    "perf-compare": "ariakit perf-compare",
    "og-image-clean": "rimraf public/og-image",
    "og-image-generate": "node src/pages/og-image/_generate-images.ts",
    "build-styles": "node src/lib/build-styles.ts"
  },
  "dependencies": {
    "@ariakit/react": "workspace:*",
    "@ariakit/react-components": "workspace:*",
    "@ariakit/react-utils": "workspace:*",
    "@ariakit/solid": "workspace:*",
    "@ariakit/solid-components": "workspace:*",
    "@ariakit/solid-utils": "workspace:*",
    "@ariakit/store": "workspace:*",
    "@ariakit/tailwind": "workspace:*",
    "@ariakit/utils": "workspace:*",
    "@astrojs/check": "0.9.9",
    "@astrojs/cloudflare": "14.1.3",
    "@astrojs/markdown-remark": "7.2.1",
    "@astrojs/mdx": "7.0.3",
    "@astrojs/react": "6.0.1",
    "@astrojs/solid-js": "7.0.1",
    "@clerk/astro": "3.4.18",
    "@fontsource-variable/inter": "5.2.8",
    "@react-aria/utils": "3.34.1",
    "@shikijs/langs": "4.3.1",
    "@shikijs/themes": "4.3.1",
    "@stackblitz/sdk": "1.11.1",
    "@stripe/stripe-js": "9.10.0",
    "@tailwindcss/vite": "4.3.3",
    "@tanstack/react-query": "5.101.2",
    "astro": "7.0.9",
    "astro-remote": "0.3.4",
    "canvas-confetti": "1.9.4",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "diff": "9.0.0",
    "hast-util-to-text": "4.0.2",
    "html-entities": "2.6.0",
    "import-meta-resolve": "4.2.0",
    "kleur": "4.1.5",
    "lodash-es": "4.18.1",
    "lucide-react": "1.24.0",
    "match-sorter": "8.3.0",
    "motion": "12.42.2",
    "parse-numeric-range": "1.3.0",
    "playwright": "1.60.0",
    "pluralize": "8.0.0",
    "prettier": "3.9.5",
    "react": "19.2.7",
    "react-aria-components": "1.19.0",
    "react-dom": "19.2.7",
    "read-package-up": "12.0.0",
    "rehype-autolink-headings": "7.1.0",
    "rehype-parse": "9.0.1",
    "shiki": "4.3.1",
    "solid-js": "1.9.14",
    "stripe": "22.3.2",
    "tailwindcss": "4.3.3",
    "ts-morph": "28.0.0",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0",
    "use-local-storage-state": "19.5.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@ariakit/scripts": "workspace:*",
    "@ariakit/test": "workspace:*",
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.60.0",
    "@types/canvas-confetti": "1.9.0",
    "@types/hast": "3.0.5",
    "@types/lodash-es": "4.17.12",
    "@types/node": "24.13.3",
    "@types/pluralize": "0.0.33",
    "@types/pngjs": "6.0.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "nextjs": "workspace:*",
    "pixelmatch": "7.2.0",
    "pngjs": "7.0.0",
    "prettier-plugin-tailwindcss": "0.8.1",
    "rimraf": "6.1.3",
    "vite": "8.1.5",
    "vitest": "4.1.10",
    "wrangler": "4.111.0"
  }
}
