import { containerSizeContent } from "#app/lib/container-size.ts";
import { container } from "@ariakit/ui/styles/container.ts";
import { heading } from "@ariakit/ui/styles/heading.ts";
import type { HTMLTag, Polymorphic } from "astro/types";
import { clsx } from "clsx";

type Props<T extends HTMLTag> = Polymorphic<{ as: T }> & {
  hasSidebar?: boolean;
  /**
   * Overrides the visual size when it should differ from the rendered
   * element, which sizes the heading automatically.
   */
  $level?: ReturnType<typeof heading.getVariants>["$level"];
};

const {
  as: Tag = "h1",
  hasSidebar = true,
  $level,
  class: className,
  style,
  ...props
} = Astro.props as Props<HTMLTag>;

// The heading spread below is the element's single class/style source, so
// the container channel is folded into it.
// The caller style also goes through the cv chain: Astro doesn't merge
// duplicate style attributes.
const containerProps = container.html({
  $size: hasSidebar ? containerSizeContent : "default",
  $p: "none",
  style,
});
---

<Tag
  {...heading.html({
    $level,
    class: clsx(
      "relative scroll-mt-[calc(var(--header-height)+1.25em)]",
      containerProps.class,
      className,
    ),
    style: containerProps.style,
  })}
  {...props}
>
  <slot />
</Tag>
