import { button, buttonLabel, buttonSlot } from "@ariakit/ui/styles/button.ts";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"a"> {
  /**
   * When true, sets `aria-current="page"` for the current chip link.
   */
  current?: boolean;
}

const { current, class: className, style, ...props } = Astro.props as Props;
const ariaCurrent = current ? "page" : undefined;
---

<a
  aria-current={ariaCurrent}
  {...button.html({
    $rounded: "full",
    $size: "sm",
    $px: "lg",
    class: ["aria-[current]:ak-layer-100 scroll-m-4", className],
    // Astro doesn't merge duplicate style attributes, so the caller style
    // goes through the cv, which does.
    style,
  })}
  {...props}
>
  <span {...buttonLabel.html()}>
    <slot />
  </span>
  {
    Astro.slots.has("badge") && (
      <span {...buttonSlot.html({ $kind: "badge" })}>
        <span>
          <slot name="badge" />
        </span>
      </span>
    )
  }
</a>
