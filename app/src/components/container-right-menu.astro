import { containerSizeContent } from "#app/lib/container-size.ts";
import { Prose } from "@ariakit/ui/html/prose.react.tsx";
import { container } from "@ariakit/ui/styles/container.ts";
import type { HTMLTag, Polymorphic } from "astro/types";

type Props<T extends HTMLTag> = Polymorphic<{ as: T }> & {
  keepSidebar?: boolean;
};

const {
  as: Tag = "div",
  keepSidebar = false,
  ...props
} = Astro.props as Props<HTMLTag>;
---

<Tag
  data-container-right-menu="true"
  class:list={[
    "grid",
    keepSidebar
      ? "grid-cols-[1fr_var(--container-sidebar)] @max-3xl:[--container-sidebar:max-content]"
      : "@3xl:grid-cols-[1fr_var(--container-sidebar)]",
    props.class,
  ]}
  {...props}
>
  <slot />
  {
    Astro.slots.has("heading") && (
      <div
        {...container.html({
          $size: containerSizeContent,
          $p: "var(--container-p)",
          class: "flex flex-col gap-4 my-16",
        })}
      >
        <slot name="heading" />
      </div>
    )
  }
  {
    Astro.slots.has("prose") && (
      <Prose
        {...container.jsx({
          class: [
            "@5xl:text-lg/loose",
            // The legacy size and gutter applied only from @3xl on, which
            // the container variants cannot express through inline styles,
            // so the container channels are written through variant classes
            // instead. --container-p is published by container-left-menu.
            "@3xl:[--_container-max-width:calc(100cqi-var(--container-sidebar))]",
            "@3xl:[--_container-padding:var(--container-p)]",
          ],
        })}
      >
        <slot name="prose" />
      </Prose>
    )
  }
  <div
    class:list={[
      "ps-3 in-data-container-left-menu:ps-0 in-data-container-left-menu:pe-3",
      !keepSidebar && "hidden @3xl:block",
    ]}
  >
    <slot name="sidebar" />
  </div>
</Tag>
