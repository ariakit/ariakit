import { Icon } from "#app/icons/icon.react.tsx";
import { button } from "@ariakit/ui/styles/button.ts";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"button"> {
  direction: "left" | "right";
}

const { direction, ...props } = Astro.props;
---

<button
  class:list={[
    "group/scroll-button h-full items-center justify-end from-(--ak-layer) from-70% to-transparent px-3 absolute top-0 z-10 hidden @3xl:flex",
    direction === "left"
      ? "bg-linear-to-r start-0 pe-6"
      : "bg-linear-to-l end-0 ps-6",
    props.class,
  ]}
  {...props}
  aria-label={`Scroll ${direction}`}
>
  {/* The wrapper button is the interactive element, so the box's own state
      variants are disabled and the resolved hover/active plugin classes are
      forced under the group variants, like the legacy forced-state
      utilities. It always lightens ($lighten 1.2 = the legacy
      ak-layer-lighten-6) so it stays visible over the scrolled content. */}
  <div
    {...button.html({
      $rounded: "full",
      $p: "none",
      $lightnessOffset: false,
      $lighten: 1.2,
      $hoverOffset: false,
      $focus: false,
      $active: false,
      class: [
        "size-8 items-center pointer-events-auto border shadow",
        "group-hover/scroll-button:ak-state-6",
        "group-active/scroll-button:origin-bottom group-active/scroll-button:scale-x-[98%] group-active/scroll-button:scale-y-[96%]",
      ],
    })}
  >
    <slot>
      <Icon name={direction === "left" ? "chevronLeft" : "chevronRight"} />
    </slot>
  </div>
</button>
