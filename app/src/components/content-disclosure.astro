import type { ComponentProps } from "react";
import { ContentDisclosure } from "./content-disclosure.react.tsx";

interface Props
  extends Omit<
    ComponentProps<typeof ContentDisclosure>,
    "label" | "prose" | "className" | "children" | "open" | "setOpen"
  > {
  class?: string;
  /** Mirrors the native `<details open>` attribute. */
  open?: boolean | string | null;
}

const { class: className, open, ...props } = Astro.props;

// Markdown `<details open>` arrives as an empty string; treat any non-null,
// non-false value as the native boolean attribute would.
const defaultOpen = open != null && open !== false ? true : undefined;
---

<ContentDisclosure
  client:visible={{ rootMargin: "50%" }}
  prose
  className={className}
  defaultOpen={defaultOpen}
  {...props}
>
  <Fragment slot="label"><slot name="summary" /></Fragment>
  <slot />
</ContentDisclosure>
