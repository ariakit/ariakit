import { select } from "@ariakit/ui/styles/select.ts";
import type { ComponentProps, HTMLAttributes } from "astro/types";
import SelectOption from "./select-option.astro";

interface Props extends HTMLAttributes<"select"> {
  options?: ComponentProps<typeof SelectOption>[];
  submitOnChange?: boolean;
}

const { options, submitOnChange, class: className, style, ...props } = Astro.props;
---

{/* The cv is spread onto the native element to keep the zero-JS behavior;
    its default lightness offset covers the legacy ak-layer ak-layer-6. */}
<select
  data-select
  data-submit-on-change={submitOnChange || undefined}
  {...props}
  {...select.html({
    class: className,
    // Astro doesn't merge duplicate style attributes, so the caller style
    // goes through the cv, which merges it.
    style,
  })}
>
  <slot />
  {options?.map((option) => <SelectOption {...option} />)}
</select>

<script>
  const selects = document.querySelectorAll<HTMLSelectElement>("[data-select]");

  for (const select of selects) {
    select.addEventListener("keydown", (event) => {
      if (event.key === "Enter") {
        if (event.target !== select) return;
        event.preventDefault();
        select.showPicker();
      }
    });
    select.form?.addEventListener("change", () => {
      if (!select.dataset.submitOnChange) return;
      select.form?.submit();
    });
  }
</script>
