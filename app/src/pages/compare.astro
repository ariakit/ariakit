 *
 * This software is proprietary. See the license.md file in the root of this
 * package for licensing terms.
 *
 * SPDX-License-Identifier: UNLICENSED
 */
import { Badge, BadgeLabel, BadgeSlot } from "@ariakit/ui/html/badge.react.tsx";
import * as ButtonReact from "@ariakit/ui/html/button.react.tsx";
import {
  CheckboxCard,
  CheckboxCardCheck,
  CheckboxCardContent,
  CheckboxCardDescription,
  CheckboxCardLabel,
  CheckboxCardSlot,
} from "@ariakit/ui/html/checkbox-card.react.tsx";
import { Container } from "@ariakit/ui/html/container.react.tsx";
import { Heading } from "@ariakit/ui/html/heading.react.tsx";
import { Input } from "@ariakit/ui/html/input.react.tsx";
import { Kbd } from "@ariakit/ui/html/kbd.react.tsx";
import { Link } from "@ariakit/ui/html/link.react.tsx";
import {
  Progress,
  ProgressCircular,
} from "@ariakit/ui/ariakit/progress.react.tsx";
import { Radio } from "@ariakit/ui/html/radio.react.tsx";
import { checkboxCardGrid } from "@ariakit/ui/styles/checkbox-card.ts";
import { containerSize } from "@ariakit/ui/styles/container.ts";
import { input } from "@ariakit/ui/styles/input.ts";
import { option } from "@ariakit/ui/styles/option.ts";
import {
  CheckIcon,
  ChevronDownIcon,
  CopyIcon,
  ExternalLinkIcon,
  SearchIcon,
} from "lucide-react";
import {
  CompareDialogLegacy,
  CompareDialogNew,
  ComparePopoverLegacy,
  ComparePopoverNew,
  CompareTooltipLegacy,
  CompareTooltipNew,
} from "./_compare-popover.react.tsx";
import {
  CompareDisclosureLegacy,
  CompareDisclosureNew,
} from "./_compare-disclosure.react.tsx";
import { CompareListLegacy, CompareListNew } from "./_compare-list.react.tsx";
import {
  CompareSidebarLegacy,
  CompareSidebarNew,
} from "./_compare-sidebar.react.tsx";
import { CompareNavLegacy, CompareNavNew } from "./_compare-nav.react.tsx";
import {
  CompareProseLegacy,
  CompareProseNew,
} from "./_compare-prose.react.tsx";
import {
  CompareTableLegacy,
  CompareTableNew,
} from "./_compare-table.react.tsx";
import {
  CompareSelectLegacy,
  CompareSelectNew,
} from "./_compare-select.react.tsx";
import { CompareTabs, CompareTabsGliders } from "./_compare-tabs.react.tsx";
import Layout from "./_layout.astro";
---

<Layout>
  <div class="flex flex-col gap-6 p-4 max-w-6xl">
    <div
      class="grid grid-cols-[8rem_1fr_1fr] gap-x-6 gap-y-5 items-start [&_h3]:ak-ink-60 [&_h3]:text-sm [&_h3]:font-medium [&_h3]:pt-2"
    >
      <div></div>
      <h2 class="text-base font-semibold sticky top-0 ak-layer py-2 z-10">
        main <span class="ak-ink-60 font-normal">(ak-*.css)</span>
      </h2>
      <h2 class="text-base font-semibold sticky top-0 ak-layer py-2 z-10">
        ariakit-ui
      </h2>

      <h3>Button</h3>
      <div class="theme-main compare-cell">
        <button class="ak-button ak-layer ak-layer-6">Button</button>
        <button class="ak-button ak-layer ak-layer-primary">Brand</button>
        <button class="ak-button-classic">Classic</button>
        <button class="ak-button ak-layer ak-layer-6" disabled>Disabled</button>
        <button class="ak-button-classic" disabled>Disabled classic</button>
      </div>
      <div class="compare-cell">
        <ButtonReact.Button>Button</ButtonReact.Button>
        <ButtonReact.Button $layer="brand">Brand</ButtonReact.Button>
        <ButtonReact.Button $kind="bevel">Classic</ButtonReact.Button>
        <ButtonReact.Button disabled>Disabled</ButtonReact.Button>
        <ButtonReact.Button $kind="bevel" disabled>
          Disabled classic
        </ButtonReact.Button>
      </div>

      <h3>Ghost, pill, square</h3>
      <div class="theme-main compare-cell">
        <button class="ak-button">Ghost</button>
        <button class="ak-button rounded-full ak-layer ak-layer-6 text-sm">
          Follow
        </button>
        <button
          class="ak-button ak-layer ak-layer-6 ak-button-square-7 [&_svg]:size-4"
        >
          <CopyIcon />
          <span class="sr-only">Copy</span>
        </button>
      </div>
      <div class="compare-cell">
        <ButtonReact.Button $layer="ghost">Ghost</ButtonReact.Button>
        <ButtonReact.Button $rounded="full" $size="sm" $px="lg">
          Follow
        </ButtonReact.Button>
        <ButtonReact.Button>
          <ButtonReact.ButtonSlot>
            <CopyIcon />
          </ButtonReact.ButtonSlot>
          <span class="sr-only">Copy</span>
        </ButtonReact.Button>
      </div>

      <h3>Button slots</h3>
      <div class="theme-main compare-cell">
        <button class="ak-button ak-layer ak-layer-6 [&_svg]:size-4">
          <CopyIcon />
          Copy
        </button>
        <button class="ak-button ak-layer ak-layer-6 [&_svg]:size-4">
          Menu
          <ChevronDownIcon />
        </button>
        <a
          class="ak-button ak-frame ak-frame-field/1 ak-layer ak-layer-6 text-sm rounded-full gap-0"
        >
          <span>Components</span>
          <span
            class="-ms-0.5 ak-ink-0 rounded-full ak-edge-0 ring px-1.5 ak-layer ak-layer-6 min-w-(--ak-button-leading) text-center"
          >
            26
          </span>
        </a>
        <button class="ak-button ak-layer ak-layer-6 [&_svg]:size-4" disabled>
          <CopyIcon />
          Disabled
        </button>
      </div>
      <div class="compare-cell">
        <ButtonReact.Button>
          <ButtonReact.ButtonSlot>
            <CopyIcon />
          </ButtonReact.ButtonSlot>
          <ButtonReact.ButtonLabel>Copy</ButtonReact.ButtonLabel>
        </ButtonReact.Button>
        <ButtonReact.Button>
          <ButtonReact.ButtonLabel>Menu</ButtonReact.ButtonLabel>
          <ButtonReact.ButtonSlot $mx="closeGap">
            <ChevronDownIcon />
          </ButtonReact.ButtonSlot>
        </ButtonReact.Button>
        <ButtonReact.Button $rounded="full" $size="sm" $px="lg">
          <ButtonReact.ButtonLabel>Components</ButtonReact.ButtonLabel>
          <ButtonReact.ButtonSlot $kind="badge">
            <span>26</span>
          </ButtonReact.ButtonSlot>
        </ButtonReact.Button>
        <ButtonReact.Button disabled>
          <ButtonReact.ButtonSlot>
            <CopyIcon />
          </ButtonReact.ButtonSlot>
          <ButtonReact.ButtonLabel>Disabled</ButtonReact.ButtonLabel>
        </ButtonReact.Button>
      </div>

      <h3>Rich button</h3>
      <div class="theme-main compare-cell">
        <span class="ak-ink-60 text-sm">(no legacy equivalent)</span>
      </div>
      <div class="compare-cell">
        <ButtonReact.Button $rounded="full" $px="xl" $gap="lg">
          {/* xl spans the two text rows; full would bleed through the
              padding and fill the button's entire height */}
          <ButtonReact.ButtonSlot $kind="avatar" $size="xl" $rowSpan={2}>
            <span class="size-full bg-linear-to-br from-blue-500 to-pink-500"
            ></span>
          </ButtonReact.ButtonSlot>
          <ButtonReact.ButtonContent>
            <ButtonReact.ButtonLabel>Diego Haz</ButtonReact.ButtonLabel>
            <ButtonReact.ButtonDescription>
              @diegohaz
            </ButtonReact.ButtonDescription>
          </ButtonReact.ButtonContent>
          <ButtonReact.ButtonSlot $rowSpan={2} $square={false}>
            <ChevronDownIcon />
          </ButtonReact.ButtonSlot>
        </ButtonReact.Button>
        <ButtonReact.Button $rounded="full" $size="sm" $px="lg">
          <ButtonReact.ButtonLabel>Following</ButtonReact.ButtonLabel>
          <ButtonReact.ButtonSlot $lightnessOffset>
            <span class="text-[0.875em] ak-ink-60">32</span>
          </ButtonReact.ButtonSlot>
        </ButtonReact.Button>
      </div>

      <h3>Aurora</h3>
      <div class="theme-main compare-cell">
        {/* ak-frame-border makes the legacy ring visible: its 1px fallback
            is dead (registered property), so borderless legacy buttons
            never rendered the effect */}
        <button
          class="ak-button ak-frame-border ak-button-aurora-(--color-purple-500)/(--color-pink-500)"
        >
          Aurora
        </button>
      </div>
      <div class="compare-cell">
        <ButtonReact.Button
          $border
          $borderType="border"
          $aurora="var(--color-purple-500)"
          $auroraTo="var(--color-pink-500)"
        >
          Aurora
        </ButtonReact.Button>
        <ButtonReact.Button
          $aurora="var(--color-purple-500)"
          $auroraTo="var(--color-pink-500)"
        >
          Borderless
        </ButtonReact.Button>
      </div>

      <h3>Badge</h3>
      <div class="theme-main compare-cell">
        <span class="ak-badge ak-layer ak-layer-6 rounded-full">
          <span>Badge</span>
        </span>
        <span class="ak-badge-primary">
          <span>Primary</span>
        </span>
        <span class="ak-badge-(--color-green-700)">
          <span>Success</span>
        </span>
        <span class="ak-badge-(--color-red-600)">
          <span>Danger</span>
        </span>
        <span
          class="ak-badge-(color:--status-color) ak-frame-border text-sm gap-2"
          style="--status-color: var(--color-purple-600)"
        >
          <span>Processing</span>
        </span>
      </div>
      <div class="compare-cell">
        <Badge>
          <BadgeLabel>Badge</BadgeLabel>
        </Badge>
        <Badge $layer="brand">
          <BadgeLabel>Primary</BadgeLabel>
        </Badge>
        <Badge $layer="success">
          <BadgeLabel>Success</BadgeLabel>
        </Badge>
        <Badge $layer="danger">
          <BadgeLabel>Danger</BadgeLabel>
        </Badge>
        <Badge $layer="var(--color-purple-600)" $size="sm" $gap="xl">
          <BadgeLabel>Processing</BadgeLabel>
        </Badge>
      </div>

      <h3>Badge content</h3>
      <div class="theme-main compare-cell">
        <span class="ak-badge-primary [&_svg]:size-3.5">
          <CheckIcon className="ak-badge-icon" />
          <span>Icon</span>
        </span>
        <span class="ak-badge-primary [&_svg]:size-3.5">
          <span>New</span>
          <ChevronDownIcon className="ak-badge-icon" />
        </span>
        <span class="ak-badge-primary max-w-40">
          <span class="truncate">Very long badge text that truncates</span>
        </span>
        <button class="ak-badge ak-button ak-layer ak-layer-6">v1.0.0</button>
      </div>
      <div class="compare-cell">
        <Badge $layer="brand">
          <BadgeSlot>
            <CheckIcon />
          </BadgeSlot>
          <BadgeLabel>Icon</BadgeLabel>
        </Badge>
        <Badge $layer="brand">
          <BadgeLabel>New</BadgeLabel>
          <BadgeSlot>
            <ChevronDownIcon />
          </BadgeSlot>
        </Badge>
        <Badge $layer="brand" className="max-w-40">
          <BadgeLabel $truncate>Very long badge text that truncates</BadgeLabel>
        </Badge>
        <ButtonReact.Button $size="xs" $rounded="full" $p={1} $px="lg">
          <ButtonReact.ButtonLabel>v1.0.0</ButtonReact.ButtonLabel>
        </ButtonReact.Button>
      </div>

      <h3>Radio</h3>
      <div class="theme-main compare-cell">
        <label class="ak-radio">
          <input name="legacy-radio" type="radio" checked />
          Comfortable
        </label>
        <label class="ak-radio">
          <input name="legacy-radio" type="radio" />
          Compact
        </label>
        <label class="ak-radio">
          <input name="legacy-radio" type="radio" disabled />
          Disabled
        </label>
        <label class="ak-radio">
          <input name="legacy-radio-2" type="radio" checked disabled />
          Checked disabled
        </label>
      </div>
      <div class="compare-cell">
        <Radio name="new-radio" defaultChecked>Comfortable</Radio>
        <Radio name="new-radio">Compact</Radio>
        <Radio name="new-radio" disabled>Disabled</Radio>
        <Radio name="new-radio-2" defaultChecked disabled>
          Checked disabled
        </Radio>
      </div>

      <h3>Checkbox card</h3>
      <div class="theme-main compare-cell">
        <div class="ak-checkbox-card-grid w-full">
          <label class="ak-checkbox-card">
            <input type="checkbox" />
            <span class="ak-checkbox-card-check"></span>
            <span class="ak-checkbox-card-label">Culture</span>
          </label>
          <label class="ak-checkbox-card">
            <input type="checkbox" checked />
            <span class="ak-checkbox-card-check"></span>
            <span class="ak-checkbox-card-label">Finance</span>
          </label>
          <label class="ak-checkbox-card">
            <input type="checkbox" disabled />
            <span class="ak-checkbox-card-check"></span>
            <span class="ak-checkbox-card-label">Disabled</span>
          </label>
          <label class="ak-checkbox-card">
            <input type="checkbox" checked disabled />
            <span class="ak-checkbox-card-check"></span>
            <span class="ak-checkbox-card-label">Disabled checked</span>
          </label>
        </div>
      </div>
      <div class="compare-cell">
        <div {...checkboxCardGrid.html({ class: "w-full" })}>
          <CheckboxCard>
            <CheckboxCardCheck />
            <CheckboxCardLabel>Culture</CheckboxCardLabel>
          </CheckboxCard>
          <CheckboxCard defaultChecked>
            <CheckboxCardCheck />
            <CheckboxCardLabel>Finance</CheckboxCardLabel>
          </CheckboxCard>
          <CheckboxCard disabled>
            <CheckboxCardCheck />
            <CheckboxCardLabel>Disabled</CheckboxCardLabel>
          </CheckboxCard>
          <CheckboxCard defaultChecked disabled>
            <CheckboxCardCheck />
            <CheckboxCardLabel>Disabled checked</CheckboxCardLabel>
          </CheckboxCard>
        </div>
      </div>

      <h3>Checkbox card content</h3>
      <div class="theme-main compare-cell">
        <div class="ak-checkbox-card-grid w-full">
          <label class="ak-checkbox-card">
            <input type="checkbox" />
            <span class="ak-checkbox-card-label">Culture</span>
            <span class="ak-checkbox-card-check"></span>
            <span class="ak-checkbox-card-description">Art and heritage</span>
          </label>
          <label class="ak-checkbox-card">
            <input type="checkbox" />
            <span class="ak-checkbox-card-check"></span>
            <div class="ak-checkbox-card-content">
              <span class="ak-checkbox-card-label">Health</span>
              <span class="ak-checkbox-card-description">Wellness tips</span>
            </div>
          </label>
          <label class="ak-checkbox-card">
            <input type="checkbox" />
            <div class="ak-checkbox-card-image">
              <span class="size-10 rounded-full bg-linear-to-br from-blue-500 to-pink-500"
              ></span>
            </div>
            <div class="ak-checkbox-card-content">
              <span class="ak-checkbox-card-label">Culture</span>
              <span class="ak-checkbox-card-check"></span>
              <span class="ak-checkbox-card-description">With image</span>
            </div>
          </label>
        </div>
      </div>
      <div class="compare-cell">
        <div {...checkboxCardGrid.html({ class: "w-full" })}>
          <CheckboxCard>
            <CheckboxCardLabel>Culture</CheckboxCardLabel>
            <CheckboxCardCheck />
            <CheckboxCardDescription>Art and heritage</CheckboxCardDescription>
          </CheckboxCard>
          <CheckboxCard>
            <CheckboxCardCheck />
            <CheckboxCardContent>
              <CheckboxCardLabel>Health</CheckboxCardLabel>
              <CheckboxCardDescription>Wellness tips</CheckboxCardDescription>
            </CheckboxCardContent>
          </CheckboxCard>
          <CheckboxCard>
            <CheckboxCardSlot $kind="avatar" $size="full" $rowSpan={2}>
              <span class="size-full bg-linear-to-br from-blue-500 to-pink-500"
              ></span>
            </CheckboxCardSlot>
            <CheckboxCardContent>
              <CheckboxCardLabel>Culture</CheckboxCardLabel>
              <CheckboxCardDescription>With image</CheckboxCardDescription>
            </CheckboxCardContent>
            <CheckboxCardCheck />
          </CheckboxCard>
        </div>
      </div>

      <h3>Checkbox chip</h3>
      <div class="theme-main compare-cell">
        <label class="ak-checkbox-card ak-checkbox-card-round">
          <input type="checkbox" />
          <span class="ak-checkbox-card-label">History</span>
          <span class="ak-checkbox-card-check"></span>
        </label>
        <label class="ak-checkbox-card ak-checkbox-card-round">
          <input type="checkbox" checked />
          <span class="ak-checkbox-card-label">Food</span>
          <span class="ak-checkbox-card-check"></span>
        </label>
      </div>
      <div class="compare-cell">
        <CheckboxCard $rounded="full" $forceRounded $p={2}>
          <CheckboxCardLabel>History</CheckboxCardLabel>
          <CheckboxCardCheck />
        </CheckboxCard>
        <CheckboxCard $rounded="full" $forceRounded $p={2} defaultChecked>
          <CheckboxCardLabel>Food</CheckboxCardLabel>
          <CheckboxCardCheck />
        </CheckboxCard>
      </div>

      <h3>Kbd</h3>
      <div class="theme-main compare-cell">
        <span class="flex items-center gap-1">
          Press <kbd class="ak-kbd">⌘</kbd><kbd class="ak-kbd">K</kbd> to search
        </span>
        <kbd class="ak-kbd grid place-items-center aspect-square h-7">K</kbd>
      </div>
      <div class="compare-cell">
        <span class="flex items-center gap-1">
          Press <Kbd>⌘</Kbd><Kbd>K</Kbd> to search
        </span>
        <Kbd className="grid place-items-center aspect-square h-7">K</Kbd>
      </div>

      <h3>Kbd on layers</h3>
      <div class="theme-main compare-cell">
        <span
          class="ak-layer ak-layer-black ak-frame ak-frame-lg/3 flex items-center gap-1"
        >
          Press <kbd class="ak-kbd">Shift</kbd><kbd class="ak-kbd">Esc</kbd> here
        </span>
        <span
          class="ak-layer ak-layer-5 ak-frame ak-frame-lg/3 flex items-center gap-1"
        >
          Press <kbd class="ak-kbd">Shift</kbd><kbd class="ak-kbd">Esc</kbd> here
        </span>
      </div>
      <div class="compare-cell">
        <span
          class="ak-layer ak-layer-black ak-frame ak-frame-lg/3 flex items-center gap-1"
        >
          Press <Kbd>Shift</Kbd><Kbd>Esc</Kbd> here
        </span>
        <span
          class="ak-layer ak-layer-5 ak-frame ak-frame-lg/3 flex items-center gap-1"
        >
          Press <Kbd>Shift</Kbd><Kbd>Esc</Kbd> here
        </span>
      </div>

      <h3>Progress</h3>
      <div class="theme-main compare-cell">
        <div
          role="progressbar"
          class="ak-progress ak-progress-value-[0.6] after:ak-progress-fill w-40"
        >
        </div>
        <div class="size-16">
          <div class="ak-progress-circular">
            <div class="ak-progress-circular-fill ak-progress-value-[0.6]">
            </div>
          </div>
        </div>
      </div>
      <div class="compare-cell">
        {/* max-w composes with the cv's w-full; a plain w-* utility would
            lose to it by stylesheet order */}
        <Progress value={0.6} className="max-w-40" />
        <div class="size-16">
          <ProgressCircular value={0.6} />
        </div>
      </div>

      <h3>Option</h3>
      <div class="theme-main compare-cell">
        <div class="flex flex-col gap-1 w-40">
          <div class="ak-option" tabindex="0">Apple</div>
          <div class="ak-option" tabindex="0">Banana</div>
          <div class="ak-option" aria-disabled="true">Cherry</div>
        </div>
      </div>
      <div class="compare-cell">
        <div class="flex flex-col gap-1 w-40">
          <div {...option.html({})} tabindex="0">Apple</div>
          {/* data-focus-visible shows the virtual-focus highlight Ariakit
              composites need; legacy only reacted to real :focus-visible */}
          <div {...option.html({})} tabindex="0" data-focus-visible>
            Banana
          </div>
          <div {...option.html({})} aria-disabled="true">Cherry</div>
        </div>
      </div>

      <h3>Popover</h3>
      <div class="theme-main compare-cell">
        <ComparePopoverLegacy client:load />
      </div>
      <div class="compare-cell">
        <ComparePopoverNew client:load />
      </div>

      <h3>Tooltip</h3>
      <div class="theme-main compare-cell">
        <CompareTooltipLegacy client:load />
      </div>
      <div class="compare-cell">
        <CompareTooltipNew client:load />
      </div>

      <h3>Dialog</h3>
      <div class="theme-main compare-cell">
        <CompareDialogLegacy client:load />
      </div>
      <div class="compare-cell">
        <CompareDialogNew client:load />
      </div>

      <h3>Select</h3>
      <div class="theme-main compare-cell">
        <CompareSelectLegacy client:load />
      </div>
      <div class="compare-cell">
        <CompareSelectNew client:load />
      </div>

      <h3>Disclosure</h3>
      <div class="theme-main compare-cell">
        <CompareDisclosureLegacy client:load />
      </div>
      <div class="compare-cell">
        <CompareDisclosureNew client:load />
      </div>

      <h3>List</h3>
      <div class="theme-main compare-cell">
        <CompareListLegacy client:load />
      </div>
      <div class="compare-cell">
        <CompareListNew client:load />
      </div>

      <h3>Sidebar</h3>
      <div class="theme-main compare-cell">
        <CompareSidebarLegacy client:load />
      </div>
      <div class="compare-cell">
        <CompareSidebarNew client:load />
      </div>

      <h3>Nav</h3>
      <div class="theme-main compare-cell">
        <CompareNavLegacy client:load />
      </div>
      <div class="compare-cell">
        <CompareNavNew client:load />
      </div>

      <h3>Table</h3>
      <div class="theme-main compare-cell">
        <CompareTableLegacy client:load />
      </div>
      <div class="compare-cell">
        <CompareTableNew client:load />
      </div>

      <h3>Prose</h3>
      <div class="theme-main compare-cell">
        <CompareProseLegacy client:load />
      </div>
      <div class="compare-cell">
        <CompareProseNew client:load />
      </div>

      <h3>Tabs</h3>
      <div class="theme-main compare-cell">
        <div
          class="ak-tabs ak-layer ak-layer-lighten-6 ak-frame ak-frame-container/container ak-frame-border overflow-clip w-full"
        >
          <div role="tablist" class="ak-tab-list">
            <button
              role="tab"
              id="legacy-tab-1"
              aria-selected="true"
              class="ak-tab-folder"
            >
              <div>Profile</div>
            </button>
            <button
              role="tab"
              id="legacy-tab-2"
              aria-selected="false"
              class="ak-tab-folder"
            >
              <div>Settings</div>
            </button>
            <button
              role="tab"
              id="legacy-tab-3"
              aria-selected="false"
              class="ak-tab-folder"
            >
              <div>Activity</div>
            </button>
          </div>
          <div
            role="tabpanel"
            aria-labelledby="legacy-tab-1"
            class="ak-tab-panel"
          >
            <p class="ak-frame ak-frame-p-2">Profile panel</p>
          </div>
        </div>
      </div>
      <div class="compare-cell">
        <CompareTabs client:load />
      </div>

      <h3>Tabs with gliders</h3>
      <div class="theme-main compare-cell">
        <span class="ak-ink-60 text-sm">
          (no legacy equivalent: per-tab hover/selected styles only)
        </span>
      </div>
      <div class="compare-cell">
        <CompareTabsGliders client:load />
      </div>

      <h3>Input</h3>
      <div class="theme-main compare-cell">
        <input class="ak-input" placeholder="Search docs…" />
