import { Badge, BadgeLabel, BadgeSlot } from "@ariakit/ui/html/badge.react.tsx";
import { Badge as BadgeSolid } from "@ariakit/ui/html/badge.solid.tsx";
import * as ButtonReact from "@ariakit/ui/html/button.react.tsx";
import * as ButtonSolid from "@ariakit/ui/html/button.solid.tsx";
import {
  CheckboxCard,
  CheckboxCardCheck,
  CheckboxCardContent,
  CheckboxCardDescription,
  CheckboxCardLabel,
} from "@ariakit/ui/html/checkbox-card.react.tsx";
import { checkboxCardGrid } from "@ariakit/ui/styles/checkbox-card.ts";
import { Kbd } from "@ariakit/ui/html/kbd.react.tsx";
import {
  CheckIcon,
  ChevronDownIcon,
  CircleCheckBigIcon,
  CopyIcon,
  SettingsIcon,
  UserIcon,
} from "lucide-react";
import { IndexTabs } from "./_index-tabs.react.tsx";
import Layout from "./_layout.astro";
---

<Layout>
  Soon

  <div class="flex flex-wrap gap-2 items-center p-2">
    <button
      class="ak-layer ak-layer-10 ak-frame ak-frame-lg/2 ak-frame-border hover:ak-state-10 active:ak-state-darken-3 focus-visible:ak-outline focus-visible:ak-outline-brand focus-visible:outline-2 focus-visible:outline-offset-1"
    >
      Button
    </button>
    <ButtonSolid.Button $invert>
      <ButtonSolid.ButtonSlot>
        <CopyIcon />
      </ButtonSolid.ButtonSlot>
      Button
    </ButtonSolid.Button>
    <ButtonSolid.Button $text="brand" $textPush={2}>
      <ButtonSolid.ButtonLabel $text="danger">Button</ButtonSolid.ButtonLabel>
      <ButtonSolid.ButtonSlot $mx="closeGap">
        <ChevronDownIcon />
      </ButtonSolid.ButtonSlot>
    </ButtonSolid.Button>
    <ButtonReact.Button
      className="items-center"
      $rounded="xl"
      $activeDepth={3}
      $gap="lg"
      $gapY="none"
    >
      <ButtonReact.ButtonSlot $rowSpan={2} $size="xl">
        <span class="size-full bg-blue-500 rounded-full"></span>
      </ButtonReact.ButtonSlot>
      <ButtonReact.ButtonContent>
        <ButtonReact.ButtonLabel>Diego Haz</ButtonReact.ButtonLabel>
        <ButtonReact.ButtonDescription>
          hazdiego@gmail.com
        </ButtonReact.ButtonDescription>
      </ButtonReact.ButtonContent>
      <ButtonReact.ButtonSlot $rowSpan={2} $size="md" $square={false}>
        <ChevronDownIcon />
      </ButtonReact.ButtonSlot>
    </ButtonReact.Button>
    <button>
      <span aria-describedby="tooltip">
        <span>Lol</span>
        <span id="tooltip" aria-hidden="true">Description</span>
      </span>
    </button>
    <ButtonReact.Button $kind="bevel" disabled>
      <ButtonReact.ButtonSlot><CopyIcon /></ButtonReact.ButtonSlot>
      <ButtonReact.ButtonLabel className="max-md:sr-only">
        Button React
      </ButtonReact.ButtonLabel>
      <ButtonReact.ButtonSlot $mx="closeGap">
        <ChevronDownIcon />
      </ButtonReact.ButtonSlot>
    </ButtonReact.Button>
    <ButtonReact.Button $rounded="full" $size="sm" $px="lg">
      <ButtonReact.ButtonSlot><CheckIcon /></ButtonReact.ButtonSlot>
      <ButtonReact.ButtonLabel
        >Following
        <span class="ak-ink-60">⌘K</span>
      </ButtonReact.ButtonLabel>
      <!-- <ButtonReact.ButtonAccessory /> -->
      <ButtonReact.Button $rounded="full" $invert $size="sm" $px="lg">
        <!-- <ButtonReact.ButtonIcon><CheckIcon /></ButtonReact.ButtonIcon> -->
        <ButtonReact.ButtonLabel>Following</ButtonReact.ButtonLabel>
        <ButtonReact.ButtonSlot $lightnessOffset>
          <span class="text-[0.875em] ak-ink-60">32</span>
        </ButtonReact.ButtonSlot>
      </ButtonReact.Button>
      <ButtonReact.Button $rounded="full" $size="sm" $px="lg">
        <!-- <ButtonReact.ButtonIcon><CheckIcon /></ButtonReact.ButtonIcon> -->
        <ButtonReact.ButtonLabel>Following</ButtonReact.ButtonLabel>
        <ButtonReact.ButtonSlot $lightnessOffset>
          <span class="text-[0.875em] ak-ink-60">32</span>
        </ButtonReact.ButtonSlot>
      </ButtonReact.Button>
    </ButtonReact.Button>

    <div class="flex flex-wrap gap-2 items-center p-2">
      <CheckboxCard
        $size="sm"
        $rounded="xl"
        $lightnessOffset={false}
        $border={false}
        $activeDepth={3}
      >
        <CheckboxCardCheck
          $rounded="auto"
          $size="sm"
          $lightnessOffset
          $borderRaw
        />
        Do this?
        <span slot="description"
          >A nice description to test this<br />dsadsad</span
        >
        <CopyIcon />
      </CheckboxCard>
      <ButtonSolid.Button>Button</ButtonSolid.Button>
      <ButtonSolid.Button $layer="brand">
        <ButtonSolid.ButtonSlot>
          <CopyIcon />
        </ButtonSolid.ButtonSlot>
        <ButtonSolid.ButtonLabel>Buttons</ButtonSolid.ButtonLabel>
        <ButtonSolid.ButtonSlot $mx="closeGap">
          <ChevronDownIcon />
        </ButtonSolid.ButtonSlot>
      </ButtonSolid.Button>
      <ButtonSolid.Button $lightnessOffset={false} $border>
        Button
      </ButtonSolid.Button>
      <ButtonSolid.Button>
        <CopyIcon slot="iconStart" />
        Button
      </ButtonSolid.Button>
      <ButtonSolid.Button disabled>
        Button dhsajkdhk adsadsa
        <ChevronDownIcon slot="iconEnd" />
      </ButtonSolid.Button>
      <Badge>
        <BadgeSlot>
          <CopyIcon />
        </BadgeSlot>
        <BadgeLabel>Badge Astro</BadgeLabel>
      </Badge>
      <BadgeSolid $layer="danger" $size="lg">
        <BadgeSlot>
          <CopyIcon />
        </BadgeSlot>
        <BadgeLabel>Badge Solid</BadgeLabel>
      </BadgeSolid>
      <BadgeSolid $layer="danger" $size="lg">
        <BadgeSlot>
          <CopyIcon />
        </BadgeSlot>
        <BadgeLabel>Badge Solid</BadgeLabel>
      </BadgeSolid>
      <Badge>
        <BadgeSlot>
          <CopyIcon />
        </BadgeSlot>
        <BadgeLabel>Badge</BadgeLabel>
      </Badge>

      <Badge $layer="brand" $border>
        <BadgeLabel>Badge Border</BadgeLabel>
      </Badge>
      <Badge>
        <BadgeSlot>
          <CopyIcon />
        </BadgeSlot>
        <BadgeLabel>Badge</BadgeLabel>
      </Badge>
      <Badge $layer="brand" $hue="complementary">
        <BadgeSlot>
          <CopyIcon />
        </BadgeSlot>
        <BadgeLabel>Badge</BadgeLabel>
      </Badge>
      <Badge $layer="brand" $hue="complementary" className="border-dashed">
        <BadgeSlot>
          <div class="size-full bg-blue-500 rounded-full"></div>
        </BadgeSlot>
        <BadgeLabel>Badge</BadgeLabel>
      </Badge>
      <Badge $layer="success">
        <BadgeLabel>Badge</BadgeLabel>
      </Badge>
      <Badge $layer="warning">
        <BadgeLabel>Badge</BadgeLabel>
      </Badge>
      <Badge $layer="danger">
        <BadgeLabel>Badge</BadgeLabel>
      </Badge>
    </div>
    <div
      class="grid grid-cols-2 gap-14 w-max p-40 place-content-center place-items-center mt-20"
    >
      <Badge $layer="success" className="bg-green-800">
        <span class="text-white">Success</span>
      </Badge>
      <Badge $layer="success">
        <span class="text-white">Success</span>
      </Badge>
      <Badge $layer="success" className="max-w-40">
        <BadgeSlot>
          <CircleCheckBigIcon />
        </BadgeSlot>
        <BadgeLabel $truncate>
          Success dhsakjdh ajks dsahk dsahk dhsakj
        </BadgeLabel>
      </Badge>
      <Badge $layer="success">
        <BadgeLabel>Success</BadgeLabel>
      </Badge>
      <Badge $layer="success">
        <BadgeSlot>
          <CircleCheckBigIcon />
        </BadgeSlot>
        <BadgeLabel>Success</BadgeLabel>
      </Badge>
    </div>
  </div>

  <section class="flex flex-col gap-3 p-2">
    <h2 class="ak-ink-60 text-sm font-medium">Button layers</h2>
    <div class="flex flex-wrap gap-2 items-center">
      <ButtonReact.Button>Default</ButtonReact.Button>
      <ButtonReact.Button $layer="brand">Brand</ButtonReact.Button>
      <ButtonReact.Button $layer="secondary">Secondary</ButtonReact.Button>
      <ButtonReact.Button $layer="success">Success</ButtonReact.Button>
      <ButtonReact.Button $layer="warning">Warning</ButtonReact.Button>
      <ButtonReact.Button $layer="danger">Danger</ButtonReact.Button>
      <ButtonReact.Button $layer="ghost">Ghost</ButtonReact.Button>
      <ButtonReact.Button $invert>Invert</ButtonReact.Button>
      <ButtonReact.Button $layer="brand" $hue="complementary">
        Complementary
      </ButtonReact.Button>
      <ButtonReact.Button $contrast>Contrast</ButtonReact.Button>
    </div>

    <h2 class="ak-ink-60 text-sm font-medium">Button kinds and borders</h2>
    <div class="flex flex-wrap gap-2 items-center">
      <ButtonReact.Button $kind="bevel">Bevel</ButtonReact.Button>
      <ButtonReact.Button $kind="bevel" $layer="brand">
        Bevel brand
      </ButtonReact.Button>
      <ButtonReact.Button $lightnessOffset={false} $border>
        Border
      </ButtonReact.Button>
      <ButtonReact.Button
        $lightnessOffset={false}
        $border
        $borderColor="danger"
        $borderRaw
      >
        Danger border
      </ButtonReact.Button>
      <ButtonReact.Button $border={2} $borderWeight="bold">
        Bold border
      </ButtonReact.Button>
      <ButtonReact.Button $hoverOffset={false} $hoverPush={2}>
        Hover push
      </ButtonReact.Button>
      <ButtonReact.Button disabled>Disabled</ButtonReact.Button>
      <ButtonReact.Button $kind="bevel" disabled>
        Disabled bevel
      </ButtonReact.Button>
    </div>

    <h2 class="ak-ink-60 text-sm font-medium">Button sizes</h2>
    <div class="flex flex-wrap gap-2 items-center">
      <ButtonReact.Button $size="xs">Extra small</ButtonReact.Button>
      <ButtonReact.Button $size="sm">Small</ButtonReact.Button>
      <ButtonReact.Button $size="md">Medium</ButtonReact.Button>
      <ButtonReact.Button $size="lg">Large</ButtonReact.Button>
      <ButtonReact.Button $size="xl">Extra large</ButtonReact.Button>
      <ButtonReact.Button $rounded="full" $px="xl">Pill</ButtonReact.Button>
      <ButtonReact.Button $rounded={false}>Sharp</ButtonReact.Button>
    </div>

    <h2 class="ak-ink-60 text-sm font-medium">Button group</h2>
    <div class="flex flex-wrap gap-2 items-center">
      <ButtonReact.ButtonGroup>
        <ButtonReact.Button $layer="ghost" $px="lg" aria-current="true">
          <ButtonReact.ButtonSlot>
            <UserIcon />
          </ButtonReact.ButtonSlot>
          <ButtonReact.ButtonLabel>Profile</ButtonReact.ButtonLabel>
        </ButtonReact.Button>
        <ButtonReact.ButtonSeparator />
        <ButtonReact.Button $layer="ghost" $px="lg">
          <ButtonReact.ButtonSlot>
            <SettingsIcon />
          </ButtonReact.ButtonSlot>
          <ButtonReact.ButtonLabel>Settings</ButtonReact.ButtonLabel>
        </ButtonReact.Button>
        <ButtonReact.ButtonSeparator />
        <ButtonReact.Button $layer="ghost" $px="lg">
          <ButtonReact.ButtonSlot>
            <CopyIcon />
          </ButtonReact.ButtonSlot>
          <ButtonReact.ButtonLabel>Copy</ButtonReact.ButtonLabel>
        </ButtonReact.Button>
        <ButtonReact.ButtonGlider $state="hover" />
        <ButtonReact.ButtonGlider $state="focus" />
        <ButtonReact.ButtonGlider $state="selected" />
      </ButtonReact.ButtonGroup>
    </div>

    <h2 class="ak-ink-60 text-sm font-medium">Badge chroma and text</h2>
    <div class="flex flex-wrap gap-2 items-center">
      <Badge $layer="brand" $chroma="muted">
        <BadgeLabel>Muted</BadgeLabel>
      </Badge>
      <Badge $layer="brand" $chroma="vivid">
        <BadgeLabel>Vivid</BadgeLabel>
      </Badge>
      <Badge $layer="brand" $chroma="neon">
        <BadgeLabel>Neon</BadgeLabel>
      </Badge>
      <Badge $layer="secondary">
        <BadgeLabel>Secondary</BadgeLabel>
      </Badge>
      <Badge $layer="canvas">
        <BadgeLabel>Canvas</BadgeLabel>
      </Badge>
      <Badge $layer="danger" $textChroma="neon">
        <BadgeLabel>Neon text</BadgeLabel>
      </Badge>
      <Badge $layer="warning" $textWarm={60}>
        <BadgeLabel>Warm text</BadgeLabel>
      </Badge>
    </div>

    <h2 class="ak-ink-60 text-sm font-medium">Checkbox cards</h2>
    <div {...checkboxCardGrid.html({ $minItemSize: "12rem", class: "max-w-3xl" })}>
      <CheckboxCard>
        <CheckboxCardCheck />
        <CheckboxCardLabel>Culture</CheckboxCardLabel>
      </CheckboxCard>
      <CheckboxCard defaultChecked>
        <CheckboxCardCheck />
        <CheckboxCardLabel>Finance</CheckboxCardLabel>
      </CheckboxCard>
      <CheckboxCard disabled>
        <CheckboxCardCheck />
        <CheckboxCardLabel>Disabled</CheckboxCardLabel>
      </CheckboxCard>
      <CheckboxCard defaultChecked disabled>
        <CheckboxCardCheck />
        <CheckboxCardLabel>Disabled checked</CheckboxCardLabel>
      </CheckboxCard>
      <CheckboxCard defaultChecked>
        <CheckboxCardCheck />
        <CheckboxCardContent>
          <CheckboxCardLabel>Analytics</CheckboxCardLabel>
          <CheckboxCardDescription>
            Track usage across the app
          </CheckboxCardDescription>
        </CheckboxCardContent>
      </CheckboxCard>
    </div>

    <h2 class="ak-ink-60 text-sm font-medium">Kbd</h2>
    <div class="flex flex-wrap gap-4 items-center">
      <span class="flex items-center gap-1">
        Press <Kbd>⌘</Kbd><Kbd>K</Kbd> to search
      </span>
      <span
        class="ak-layer ak-layer-black ak-frame ak-frame-lg/3 flex items-center gap-1"
      >
        Press <Kbd>Shift</Kbd><Kbd>Esc</Kbd> on a dark layer
      </span>
    </div>

    <h2 class="ak-ink-60 text-sm font-medium">Tabs</h2>
    <IndexTabs client:load />
  </section>
</Layout>
