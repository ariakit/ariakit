import PreviewPage from "#app/components/preview-page.astro";
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";

export const getStaticPaths = (async () => {
  const entries = await getCollection("previews");
  return entries.flatMap((entry) => {
    // Next.js previews are handled by the SSR redirect route.
    if (entry.id.includes("nextjs")) return [];
    return entry.data.frameworks.map((framework) => ({
      params: { preview: `${framework}/previews/${entry.id}` },
      props: { framework, entry },
    }));
  });
}) satisfies GetStaticPaths;

const { framework, entry } = Astro.props;
const { Content } = await render(entry);

const title = entry.data.title;
const fullscreen = entry.data.fullscreen;
---

<PreviewPage {Content} {framework} {fullscreen} {title} />
