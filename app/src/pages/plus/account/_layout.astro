import { InlineLink } from "#app/components/inline-link.react.tsx";
import { Icon } from "#app/icons/icon.react.tsx";
import { Logo } from "#app/icons/logo.react.tsx";
import {
  getCurrentUserPlus,
  getCurrentUserTeams,
  isSignedIn,
} from "#app/lib/auth.ts";
import { URLSchema } from "#app/lib/schemas.ts";
import type { GetPlusAccountURLParams } from "#app/lib/url.ts";
import {
  getPlusAccountPath,
  getPlusAccountURL,
  getPlusCheckoutPath,
} from "#app/lib/url.ts";
import "#app/styles/global.css";
import { badge, badgeLabel, badgeSlot } from "@ariakit/ui/styles/badge.ts";
import { button } from "@ariakit/ui/styles/button.ts";
import { container, containerSize } from "@ariakit/ui/styles/container.ts";
import { SignOutButton } from "@clerk/astro/components";
import "@fontsource-variable/inter";
import type { HTMLAttributes } from "astro/types";
import { z } from "zod";

const querySchema = z
  .object({
    redirect_url: URLSchema,
  })
  .transform((data) => ({
    redirectUrl: data.redirect_url,
  }));

const { redirectUrl } = querySchema.parse(
  Object.fromEntries(Astro.url.searchParams),
);

function removeTrailingSlash(path: string) {
  return path.replace(/\/$/, "");
}

function getLinkProps(
  path: GetPlusAccountURLParams["path"] = "",
  redirectUrl?: string | URL,
) {
  const url = getPlusAccountURL({ url: Astro.url, path, redirectUrl });
  const href = url.toString().replace(url.origin, "");
  const isCurrent =
    removeTrailingSlash(Astro.url.pathname) ===
    removeTrailingSlash(url.pathname);
  return {
    href,
    "aria-current": isCurrent ? "page" : undefined,
  } satisfies HTMLAttributes<"a">;
}

const signedIn = isSignedIn(Astro);
const currentUserPlus = await getCurrentUserPlus(Astro);
const teams = await getCurrentUserTeams(Astro);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <title>Ariakit</title>
  </head>
  <body
    {...containerSize.html({
      $size: "64rem",
      $p: 3,
      class:
        "[--color-canvas:#F9FAFA] dark:[--color-canvas:theme(--color-gray-900)] flex flex-col",
    })}
  >
    <div class="py-8 border-b ak-layer flex flex-col gap-4 ak-layer-darken-3">
      <div {...container.html()}>
        <div class="flex items-center gap-2">
          <Logo iconOnly />
          <h1 class="text-xl font-light">
            My <span class="font-semibold">Ariakit Plus</span>
          </h1>
          {
            signedIn &&
              (currentUserPlus ? (
                <span {...badge.html({ $layer: "var(--color-green-500)" })}>
                  <span {...badgeSlot.html()}>
                    <Icon name="check" />
                  </span>
                  <span {...badgeLabel.html()}>
                    {currentUserPlus === "team" || teams.size > 0
                      ? "Team"
                      : "Personal"}
                  </span>
                </span>
              ) : (
                <div class="flex items-center gap-2 text-sm ms-auto">
                  {/* $size auto inherits the parent font size, like the
                      legacy text-[length:inherit] override. */}
                  <span
                    {...badge.html({
                      $layer: "var(--color-yellow-500)",
                      $size: "auto",
                    })}
                  >
                    <span {...badgeLabel.html()}>No license</span>
                  </span>
                  {/* The $text prop replaces the legacy ak-text-yellow-500
                      classes: the Link cv's compound ui-text selectors would
                      beat plain caller classes. */}
                  <InlineLink
                    $text="var(--color-yellow-500)"
                    set:text="Purchase now"
                    href={getPlusCheckoutPath({ url: Astro.url })}
                  >
                    <Icon name="arrowRight" slot="iconRight" />
                  </InlineLink>
                </div>
              ))
          }
        </div>
      </div>
      <div {...container.html({ class: "flex flex-col gap-2" })}>
        <nav class="grid md:grid-cols-[1fr_auto] gap-8 items-center">
          <div>
            <InlineLink href={redirectUrl ?? "/"} className="text-sm group"
              ><Icon
                name="arrowLeft"
                slot="iconLeft"
                className="group-hover:-translate-x-1 transition-transform"
              />Back to site
            </InlineLink>
          </div>
          {
            signedIn && (
              <ul class="flex items-center gap-2 font-medium">
                <li>
                  {/* Legacy ak-button ak-layer paints no idle layer
                      offset. */}
                  <a
                    {...getLinkProps()}
                    {...button.html({
                      $lightnessOffset: false,
                      class: "aria-[current]:ak-layer-6",
                    })}
                  >
                    Account
                  </a>
                </li>
                <li>
                  <a
                    {...getLinkProps("team")}
                    {...button.html({
                      $lightnessOffset: false,
                      class: "aria-[current]:ak-layer-6",
                    })}
                  >
                    Team
                  </a>
                </li>
                <li>
                  <a
                    {...getLinkProps("billing", Astro.url)}
                    target="_blank"
                    {...button.html({
                      $lightnessOffset: false,
                      class: "items-center",
                    })}
                  >
                    Billing <Icon name="newWindow" />
                  </a>
                </li>
                <li>
                  <SignOutButton
                    asChild
                    redirectUrl={getPlusAccountPath({
                      url: Astro.url,
                      path: "login",
                    })}
                  >
                    <button
                      type="button"
                      {...button.html({ $lightnessOffset: false })}
                    >
                      Sign out
                    </button>
                  </SignOutButton>
                </li>
              </ul>
            )
          }
        </nav>
      </div>
    </div>

    <div {...container.html({ class: "py-12 flex-1" })}>
      <slot />
    </div>
  </body>
</html>
