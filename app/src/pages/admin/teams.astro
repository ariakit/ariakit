import { InlineLink } from "#app/components/inline-link.react.tsx";
import { Icon } from "#app/icons/icon.react.tsx";
import { isAdmin } from "#app/lib/auth.ts";
import { button } from "@ariakit/ui/styles/button.ts";
import { clerkClient } from "@clerk/astro/server";
import LayoutPagination from "./_layout-pagination.astro";
import {
  getAvatarUrl,
  getClerkInstanceUrl,
  getPageUrls,
  getPaginationData,
} from "./_utils.ts";

export const prerender = false;

if (!(await isAdmin(Astro))) {
  return Astro.redirect("/");
}

const data = await getPaginationData(Astro);

if (data instanceof Response) return data;

const { limit, offset, query } = data;
const clerk = clerkClient(Astro);
const clerkInstanceUrl = await getClerkInstanceUrl(Astro);

async function getTeamData() {
  const teams = await clerk.organizations.getOrganizationList({
    query,
    limit,
    offset,
    includeMembersCount: true,
    orderBy: "-created_at",
  });
  const pageURLs = getPageUrls(Astro, {
    limit,
    offset,
    totalCount: teams.totalCount,
  });
  return { ...teams, ...pageURLs };
}

const teams = await getTeamData();
---

<LayoutPagination
  totalCount={teams.totalCount}
  nextUrl={teams.nextUrl}
  previousUrl={teams.previousUrl}
  limit={limit}
  offset={offset}
  query={query}
>
  {/* --_container-padding is the containerSize gutter set on the layout's
      body, replacing the legacy --ak-container-p. */}
  <ul
    class="grid grid-cols-[repeat(auto-fill,minmax(20rem,1fr))] gap-(--_container-padding) py-(--_container-padding)"
  >
    {
      teams.data.map((team) => {
        const orgUrl = `${clerkInstanceUrl}/organizations/${team.id}`;
        return (
          <Fragment>
            <li>
              <div class="ak-frame ak-frame-card/card ak-layer ak-layer-lighten-6 size-full flex flex-col gap-2">
                <div class="flex items-center gap-2">
                  <img
                    src={getAvatarUrl(team.imageUrl)}
                    alt=""
                    class="size-[1em] object-cover rounded-full"
                  />
                  <div class="truncate">
                    <span class="font-semibold">{team.name}</span>{" "}
                    <span class="ak-ink-80">({team.slug})</span>
                  </div>
                </div>
                <div>
                  {/* $text false disables the Link cv's own text color: its
                      compound ui-text selectors would beat the plain
                      ak-ink-80 override. */}
                  <InlineLink
                    newWindow
                    href={`${orgUrl}?tab=members`}
                    $text={false}
                    className="ak-ink-80 text-sm"
                  >
                    {`${team.membersCount} members`}
                  </InlineLink>
                </div>
                <div class="grid grid-flow-col gap-1 mt-auto ak-frame ak-frame-cover ak-frame-p-1">
                  <a
                    href={orgUrl}
                    target="_blank"
                    {...button.html({ class: "items-center" })}
                  >
                    Clerk <Icon name="newWindow" />
                  </a>
                </div>
              </div>
            </li>
          </Fragment>
        );
      })
    }
  </ul>
</LayoutPagination>
