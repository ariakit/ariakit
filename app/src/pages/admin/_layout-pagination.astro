import { Icon } from "#app/icons/icon.react.tsx";
import Select from "#app/components/select.astro";
import { button } from "@ariakit/ui/styles/button.ts";
import { container } from "@ariakit/ui/styles/container.ts";
import { input } from "@ariakit/ui/styles/input.ts";
import Layout from "./_layout.astro";
import { getPaginationDisplayData } from "./_utils.ts";

interface Props {
  totalCount: number;
  nextUrl: string | null;
  previousUrl: string | null;
  limit: number;
  offset: number;
  query?: string;
}

const { totalCount, nextUrl, previousUrl, query, limit, offset } = Astro.props;

const cursor = { query, limit, offset };
const { currentPage, totalPages, firstResult, lastResult } =
  getPaginationDisplayData({ totalCount, limit, offset });

function getDefaultInputs(exclude: Array<keyof typeof cursor> = []) {
  const keys = Object.keys(cursor) as typeof exclude;
  return keys
    .filter((name) => !exclude.includes(name))
    .map((name) => {
      return { type: "hidden" as const, name, value: cursor[name] };
    });
}
---

<Layout>
  <div class="flex flex-col">
    <div class="sticky top-0 z-1 ak-layer ring">
      <div
        {...container.html({ class: "flex gap-2 py-2 text-sm ak-layer" })}
      >
        <div class="flex items-center gap-2">
          <div
            {...input.html({
              // The legacy ak-frame-field/0 override zeroed the field
              // padding; the nested search button provides the height.
              $p: "none",
              class: "ps-2 ak-dark:scheme-dark",
            })}
            onclick="this.querySelector('input[name=q]').focus()"
          >
            <form class="flex gap-2 items-center">
              {getDefaultInputs(["query"]).map((input) => <input {...input} />)}
              <input
                type="text"
                name="query"
                value={query}
                placeholder="Search users"
                autofocus={!!query}
              />
              <button
                {...button.html({
                  // Legacy plain ak-button paints no idle layer offset. The
                  // pinned square size replaces ak-button-square, with
                  // items-center restoring the legacy icon centering.
                  $p: "none",
                  $lightnessOffset: false,
                  class: "size-8 items-center",
                })}
              >
                <Icon name="search" strokeWidth={2} />
                <span class="sr-only">Search</span>
              </button>
            </form>
          </div>
          <form>
            {getDefaultInputs(["query"]).map((input) => <input {...input} />)}
            {/* The button's default idle offset stands in for the legacy
                ak-layer-6 (step 5 vs 6 is the accepted tolerance). */}
            <button {...button.html()}>Reset</button>
          </form>
        </div>
        <div class="flex gap-2 items-center ak-ink-80 ms-auto">
          <div class="border-(--ak-edge) border-r px-2">
            {firstResult} - {lastResult} of {totalCount}
          </div>
          <div class="flex gap-2 items-center">
            Results per page
            <form>
              {getDefaultInputs(["limit"]).map((input) => <input {...input} />)}
              <Select
                name="limit"
                submitOnChange
                options={[
                  { value: 25, selected: limit === 25 },
                  { value: 50, selected: limit === 50 },
                  { value: 100, selected: limit === 100 },
                ]}
              />
            </form>
          </div>
        </div>
        <div class="flex gap-2 items-center">
          <a
            role="link"
            href={previousUrl}
            aria-disabled={!previousUrl}
            {...button.html({ $disabled: !previousUrl, class: "items-center" })}
          >
            <Icon name="chevronLeft" aria-label="Previous" />
          </a>
          <div class="tabular-nums">
            {currentPage}/{totalPages}
          </div>
          <a
            role="link"
            href={nextUrl}
            aria-disabled={!nextUrl}
            {...button.html({ $disabled: !nextUrl, class: "items-center" })}
          >
            <Icon name="chevronRight" aria-label="Next" />
          </a>
        </div>
      </div>
    </div>
    <div class="ak-layer ak-layer-darken-6 min-h-[90vh]">
      <div {...container.html()}>
        <slot />
      </div>
    </div>
  </div>
</Layout>
