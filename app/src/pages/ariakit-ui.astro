function getExampleSource(source: string, line: number): SourceReference {
  const file = source.endsWith(".tsx")
    ? source
    : `${source}/index.react.tsx`;
  return {
    file: `app/src/examples/${file}`,
    line,
    label: `${source}:${line}`,
  };
}
---

<Layout title="Ariakit UI gallery" headerBorder>
  <style is:inline>
    .gallery-example-stage {
      container-type: inline-size;
    }

    .gallery-example[data-source="disclosure/navigation"]
      .gallery-example-stage {
      position: relative;
      min-height: 40rem;
      container-type: size;
    }

    .gallery-example[data-source="disclosure/navigation"]
      .gallery-example-stage
      .fixed {
      position: absolute;
    }
  </style>
  <div
    {...container.html({
      $size: "wider",
      class: "flex flex-col gap-20 py-12 @container/gallery",
    })}
  >
    <header class="grid gap-4 max-w-3xl">
      <p class="text-sm font-medium ak-text ak-text-brand">Clava inventory</p>
      <h1 {...heading.html({ $level: 1, class: "mb-0!" })}>
        Ariakit UI usage gallery
      </h1>
      <p class="text-lg ak-ink-70">
        Direct style calls, framework-wrapper output, local class overrides and
        every example composition that resolves to <code>@ariakit/ui</code>.
        Interactive surfaces are also rendered statically below so their styles
        stay visible without opening them.
      </p>
      <nav aria-label="Gallery sections" class="flex flex-wrap gap-2">
        <ChipLink href="#repository-compositions">Used composites</ChipLink>
        <ChipLink href="#controls">Controls</ChipLink>
        <ChipLink href="#tabs">Tabs</ChipLink>
        <ChipLink href="#glider">Glider</ChipLink>
        <ChipLink href="#building-blocks">Building blocks</ChipLink>
        <ChipLink href="#data-display">Data display</ChipLink>
        <ChipLink href="#content">Content</ChipLink>
        <ChipLink href="#overlays">Overlays</ChipLink>
        {
          exampleGroups.map(({ id, title }) => (
            <ChipLink href={`#${id}`}>{title}</ChipLink>
          ))
        }
      </nav>
    </header>

    <section id="repository-compositions" class="gallery-section">
      <header class="gallery-section-header">
        <p class="gallery-eyebrow">Used in the repository</p>
        <h2 {...heading.html({ $level: 2 })}>Shared app compositions</h2>
        <p>
          Distinct visual states implemented inside shared components. These
          were obscured when the first gallery pass only rendered their larger
          parent surfaces.
        </p>
      </header>

      <div class="gallery-grid">
        <article class="gallery-sample">
          <h3>Collection count chips</h3>
          <div class="gallery-stage flex-wrap">
            <ChipLink href="#repository-compositions" current>
              All
              <span slot="badge">68</span>
            </ChipLink>
            <ChipLink href="#repository-compositions">
              Dialog
              <span slot="badge">12</span>
            </ChipLink>
            <ChipLink href="#repository-compositions">
              Form
              <span slot="badge">9</span>
            </ChipLink>
            <ChipLink href="#repository-compositions">
              Disclosure
              <span slot="badge">7</span>
            </ChipLink>
          </div>
          <code>buttonLabel + buttonSlot $kind="badge" + aria-current</code>
          <SourceLinks
            sources={[
              { file: "app/src/pages/[...collection].astro", line: 252 },
              { file: "app/src/components/chip-link.astro", line: 25 },
            ]}
          />
        </article>

        <article class="gallery-sample">
          <h3>Code and preview segmented control</h3>
          <div class="gallery-stage flex-wrap">
            <div
              class="flex ak-layer ak-layer-darken-3 ak-frame ak-frame-full/1 ak-frame-bordering gap-(--ak-frame-padding) overflow-clip"
            >
              <button aria-selected="true" {...codeViewTabProps}>
                <span aria-hidden="true">&#9635;</span>
                Preview
              </button>
              <button aria-selected="false" {...codeViewTabProps}>
                <span aria-hidden="true">&lt;/&gt;</span>
                Code
              </button>
            </div>
            <div
              class="flex ak-layer ak-layer-darken-3 ak-frame ak-frame-full/1 ak-frame-bordering gap-(--ak-frame-padding) overflow-clip"
            >
              <button aria-selected="false" {...codeViewTabProps}>
                Preview
              </button>
              <button aria-selected="true" {...codeViewTabProps}>Code</button>
            </div>
          </div>
          <code>ghost button base + forced selected/idle app overrides</code>
          <SourceLinks
            sources={[
              { file: "app/src/components/code-block.react.tsx", line: 740 },
              { file: "app/src/components/code-block.react.tsx", line: 789 },
            ]}
          />
        </article>
      </div>
    </section>

    <section id="controls" class="gallery-section">
      <header class="gallery-section-header">
        <h2 {...heading.html({ $level: 2 })}>Controls and status</h2>
        <p>
          Unique control props and class overrides used by layouts, admin,
          Plus, content tools and examples.
        </p>
      </header>

      <div class="gallery-grid gallery-grid-compact">
        {
          buttonSamples.map(({ label, detail, attrs, disabled, sources }) => (
            <article class="gallery-sample gallery-control-sample">
              <div class="gallery-stage">
                <button {...attrs} disabled={disabled}>
                  {label}
                </button>
              </div>
              <code>{detail}</code>
              <SourceLinks {sources} />
            </article>
          ))
        }
      </div>

      <div class="gallery-grid">
        <article class="gallery-sample">
          <h3>Badges</h3>
          <div class="gallery-stage flex-wrap">
            <span
              {...badge.html({
                $layer: "brand",
                $size: "sm",
                $rounded: "lg",
                $p: 2,
                $borderType: "dashed",
                $borderWeight: "medium",
              })}
            >
              <span {...badgeLabel.html()}>Plus</span>
            </span>
            <span {...badge.html({ $layer: "var(--color-green-500)" })}>
              <span {...badgeSlot.html()} aria-hidden="true">✓</span>
              <span {...badgeLabel.html()}>Purchased</span>
            </span>
            <span
              {...badge.html({
                $layer: "var(--color-yellow-500)",
                $size: "auto",
