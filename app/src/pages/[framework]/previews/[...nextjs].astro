import "#app/styles/global.css";
import "@fontsource-variable/inter";
import { isFramework } from "#app/lib/frameworks.ts";
import {
  getNextjsPreviewId,
  getNextjsUrlFromRequest,
} from "#app/lib/nextjs.ts";
import { notFound } from "#app/lib/response.ts";
import { getEntry, render } from "astro:content";
import { env } from "cloudflare:workers";

export const prerender = false;

const nextjsExampleId = getNextjsPreviewId(Astro.url.pathname);

if (nextjsExampleId) {
  // pnpm dev-app passes NEXTJS_PORT through the spawned process env, while
  // Wrangler preview exposes it on the Cloudflare Worker env object.
  const devNextjsPort = import.meta.env.DEV
    ? import.meta.env.NEXTJS_PORT
    : undefined;
  const nextjsUrl = getNextjsUrlFromRequest({
    requestUrl: Astro.url.href,
    path: `/${nextjsExampleId}`,
    env: {
      NEXTJS_PORT: env.NEXTJS_PORT ?? devNextjsPort,
    },
  });
  return Astro.redirect(nextjsUrl, 307);
}

// This route is more specific than the generic preview catch-all, so Astro dev
// sends every /{framework}/previews/* request here. In production, those
// non-Next.js preview routes are prerendered and served as static assets.
if (!import.meta.env.DEV) return notFound();

const framework = Astro.params.framework;
const preview = Astro.params.nextjs;

if (!isFramework(framework)) return notFound();
if (!preview) return notFound();

const entry = await getEntry("previews", preview);

if (!entry) return notFound();
if (!entry.data.frameworks.includes(framework)) return notFound();

Astro.locals.framework = framework;

const { Content } = await render(entry);

const title = entry.data.title;
const fullscreen = entry.data.fullscreen;
---

<!doctype html>
<html lang="en" class:list={[!fullscreen && "min-h-[200vh]!"]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Preview {title} - Ariakit</title>
  </head>
  <body
    class:list={[
      "flex",
      !fullscreen && "items-center-safe justify-center-safe",
    ]}
  >
    <div
      class:list={[
        "@container size-full",
        !fullscreen && "p-3 flex items-center-safe justify-center-safe",
      ]}
    >
      <Content {framework} />
    </div>
  </body>
</html>
