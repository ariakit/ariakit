import { Logo } from "#app/icons/logo.react.tsx";
import "#app/styles/global.css";
import "@fontsource-variable/inter";
import { ClientRouter } from "astro:transitions";
import Meta from "#app/components/meta.astro";
import { Badge, BadgeLabel } from "@ariakit/ui/html/badge.react.tsx";
import {
  Button,
  ButtonSlot,
  ButtonLabel,
} from "@ariakit/ui/html/button.react.tsx";
import { Container } from "@ariakit/ui/html/container.react.tsx";
import { button } from "@ariakit/ui/styles/button.ts";
import { containerSize } from "@ariakit/ui/styles/container.ts";
import { Icon } from "#app/icons/icon.react.tsx";

export interface Props {
  title?: string;
  headerBorder?: boolean;
}

const { title, headerBorder = false } = Astro.props;
---

<!doctype html>
<html lang="en" transition:animate="none">
  <head>
    <slot name="meta">
      <Meta {title} />
    </slot>
    <ClientRouter />
  </head>
  <body
    {...containerSize.html({
      $size: "default",
      $p: 3,
      class:
        "overflow-x-clip [--header-height:calc(--spacing(14)+1px)] [--theme-sidebar-width:--spacing(100)]",
    })}
  >
    <div class="flex">
      <div class="flex flex-col flex-1 @container/main min-h-dvh">
        <header
          {...containerSize.html({
            $size: "default",
            class: [
              "sticky top-0 z-10",
              "ak-layer ak-light:ak-layer-lighten-6 ring",
              headerBorder || "header-scroll-driven",
            ],
          })}
        >
          {/* The stacked max-w override sorts after the container's own
              max-width rule, replacing the legacy responsive
              ak-container-size-[100dvw] (cv variants can't be responsive). */}
          <Container
            className="@max-overlap:max-w-[100dvw] transition-[max-width] flex items-center gap-3 py-2"
          >
            <div class="flex items-center gap-2"><Logo iconOnly /></div>

            <div class="flex items-center min-w-0">
              <span
                aria-hidden="true"
                class="ak-layer -me-px ak-edge-20 border-s rotate-15 flex-none h-8 block @max-3xl:hidden has-[+button:hover]:opacity-0 has-[+button:hover]:rotate-0 transition-[opacity,rotate] delay-[50ms,0ms] not-has-[+button:hover]:delay-[0ms,50ms]"
              ></span>
              <Button
                className="font-normal ak-dark:ak-ink-80 @max-3xl:hidden"
                $lightnessOffset={false}
              >
                <ButtonSlot>
                  <Icon name="react" />
                </ButtonSlot>
                <ButtonLabel>React</ButtonLabel>
              </Button>
              <span
                aria-hidden="true"
                class="ak-layer -me-px ak-edge-20 border-s rotate-15 flex-none h-8 block @max-3xl:hidden [button:hover+&]:opacity-0 [button:hover+&]:rotate-0 has-[+button:hover]:opacity-0 has-[+button:hover]:rotate-0 transition-[opacity,rotate] delay-[50ms,0ms] not-has-[+button:hover]:not-[button:hover+&]:delay-[0ms,50ms]"
              ></span>
              <Button
                className="font-normal ak-dark:ak-ink-80 min-w-0 @max-3xl:hidden"
                $lightnessOffset={false}
              >
                <ButtonLabel>Examples</ButtonLabel>
              </Button>
              <span
                aria-hidden="true"
                class="ak-layer -me-px ak-edge-20 border-s rotate-15 flex-none h-8 block [button:hover+&]:opacity-0 [button:hover+&]:rotate-0 has-[+button:hover]:opacity-0 has-[+button:hover]:rotate-0 transition-[opacity,rotate] delay-[50ms,0ms] not-has-[+button:hover]:not-[button:hover+&]:delay-[0ms,50ms]"
              ></span>
              <Button className="min-w-0" $lightnessOffset={false}>
                <ButtonLabel>{title}</ButtonLabel>
                <span class="ak-ink-0 font-normal">⌘K</span>
              </Button>
            </div>
            <div class="flex items-center gap-2 ms-auto">
              {/* Anchors can't use the html Button, so the cv is spread
                  directly; $p:1 matches the legacy ak-frame-field/1 override
                  (the field radius equals the button's own radius). */}
              <a
                href="/plus/"
                {...button.html({
                  $p: 1,
                  $lightnessOffset: false,
                  class:
                    "hover:ak-layer hover:ak-layer-brand hover:ak-layer-mix-20",
                })}
              >
                <Badge
                  $layer="brand"
                  $size="sm"
                  $rounded="lg"
                  $p={2}
                  $borderType="dashed"
                  $borderWeight="medium"
                >
                  <BadgeLabel>Plus</BadgeLabel>
                </Badge>
              </a>
              {/* The stacked responsive overrides reproduce the legacy
                  @max-4xl:ak-button-square-10; they sort after the control's
                  unstacked padding and win the ties. */}
              <Button
                id="theme-toggle"
                className="font-normal text-sm group/theme @max-4xl:aspect-square @max-4xl:px-0 @max-4xl:py-0 @max-4xl:h-10"
                $lightnessOffset={false}
              >
                <div
                  class="flex-none ak-layer ak-layer-lighten-6 rounded-full p-1 border-white bg-clip-padding bg-conic/decreasing from-violet-500 via-lime-500 to-violet-500"
                >
                  <div class="ak-layer rounded-full size-[0.4em]"></div>
                </div>
                <span class="@max-4xl:sr-only">Theme</span>
                <kbd class="ak-ink-0 font-normal @max-4xl:hidden">T</kbd>
              </Button>
            </div>
          </Container>
        </header>
        <main
          class="@max-5xl:[--container-sidebar:14rem] @max-7xl:[--container-sidebar:18rem] scroll-mt-(--header-height)"
          id="main"
        >
          <slot />
        </main>
        <footer
          {...containerSize.html({
            $size: "default",
            class: "ak-layer ak-layer-darken-6 mt-auto",
          })}
        >
          <Container>Footer</Container>
        </footer>
      </div>
      <div
        id="theme-sidebar"
        data-state="closed"
        transition:persist
        class="hidden data-[state=open]:block sticky w-(--theme-sidebar-width) h-dvh top-0 z-10 ak-layer border-s -ms-px flex-none not-data-view-transitioning:starting:w-0 data-[state=closed]:w-0 transition-discrete transition-[display,width,min-width]"
      >
        Theme
      </div>
    </div>
  </body>
</html>

<style>
  @keyframes header-solidify {
    from {
      background-color: transparent;
      box-shadow: none;
    }
  }

  .header-scroll-driven {
    animation-name: header-solidify;
    animation-duration: 1s;
    animation-timing-function: linear;
    animation-fill-mode: both;
    animation-timeline: scroll();
    /* Animate across the first pixel of scroll so it completes immediately after leaving top */
    animation-range: 0 1px;
  }
</style>

<script>
  function getThemeSidebar() {
    return document.getElementById("theme-sidebar");
  }

  function toggleSidebar() {
    const themeSidebar = getThemeSidebar();
    if (!themeSidebar) return;
    themeSidebar.dataset.state =
      themeSidebar.dataset.state !== "open" ? "open" : "closed";
  }

  function isEditableTarget(target: EventTarget | null) {
    if (!(target instanceof HTMLElement)) return false;
    if (target.closest("input, textarea, select")) return true;
    return target.isContentEditable;
  }

  document.addEventListener("astro:page-load", () => {
    const themeToggle = document.getElementById("theme-toggle");
    themeToggle?.addEventListener("click", toggleSidebar);
  });

  document.addEventListener("keydown", (event) => {
    if (event.defaultPrevented) return;
    if (event.metaKey || event.ctrlKey || event.altKey || event.shiftKey) {
      return;
    }
    if (event.key !== "t" && event.key !== "T") return;
    if (isEditableTarget(event.target)) return;
    toggleSidebar();
  });

  // Mark the sidebar as transitioning during view transitions
  document.addEventListener("astro:before-preparation", () => {
    getThemeSidebar()?.setAttribute("data-view-transitioning", "true");
  });

  document.addEventListener("astro:after-swap", () => {
    requestAnimationFrame(() => {
      getThemeSidebar()?.removeAttribute("data-view-transitioning");
    });
  });
</script>
