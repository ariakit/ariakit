{
  "extends": ["config:recommended"],
  "semanticCommits": "disabled",
  "packageRules": [
    {
      "matchFileNames": ["website/package.json"],
      "matchPackageNames": [
        "@babel/core",
        "@babel/preset-env",
        "@babel/preset-react",
        "@babel/preset-typescript",
        "@babel/types",
        "@stackblitz/sdk",
        "@stripe/react-stripe-js",
        "@stripe/stripe-js",
        "@tanstack/react-query",
        "babel-loader",
        "date-fns",
        "dotenv",
        "fast-fuzzy",
        "gray-matter",
        "hast-util-to-string",
        "hastscript",
        "marked",
        "next",
        "null-loader",
        "parse-numeric-range",
        "postcss",
        "postcss-combine-duplicated-selectors",
        "postcss-discard-comments",
        "postcss-import",
        "postcss-merge-selectors",
        "postcss-prettify",
        "prettier",
        "purgecss",
        "react-markdown",
        "read-pkg-up",
        "recast",
        "rehype-parse",
        "rehype-raw",
        "rehype-slug",
        "remark-gfm",
        "resolve-from",
        "shiki",
        "stripe",
        "tailwind-merge",
        "ts-morph",
        "typescript",
        "unified",
        "unist-util-visit",
        "use-local-storage-state",
        "webpack",
        "zod"
      ],
      "enabled": false
    },
    {
      "matchPackageNames": ["shiki"],
      "matchCurrentVersion": "/^1\\./",
      "allowedVersions": "/^1\\./"
    },
    {
      "matchPackageNames": ["tailwindcss"],
      "matchCurrentVersion": "/^3\\./",
      "enabled": false
    },
    {
      "groupName": "unified",
      "matchPackageNames": [
        "/hast/",
        "/rehype/",
        "/remark/",
        "/unified/",
        "/unist/",
        "/react-markdown/"
      ]
    },
    {
      "matchFileNames": ["website/package.json"],
      "matchPackageNames": ["/^@clerk\\//"],
      "enabled": false
    },
    {
      "groupName": "clerk",
      "matchPackageNames": ["/^@clerk\\//"]
    },
    {
      "matchFileNames": ["website/package.json"],
      "matchPackageNames": ["stripe", "/^@stripe\\//"],
      "enabled": false
    },
    {
      "groupName": "stripe",
      "matchPackageNames": ["stripe", "/^@stripe\\//"]
    },
    {
      "groupName": "monaco",
      "matchPackageNames": ["/monaco/"]
    },
    {
      "groupName": "testing-library",
      "matchPackageNames": ["/@testing-library//"]
    },
    {
      "groupName": "radix",
      "matchPackageNames": ["/@radix-ui//"]
    },
    {
      "groupName": "vite",
      "matchPackageNames": ["vite", "/^@vitejs\\//"]
    },
    {
      "matchPackageNames": ["lint-staged"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchPackageNames": [
        "@wordpress/components",
        "cross-env",
        "cross-spawn",
        "dotenv",
        "framer-motion",
        "fs-extra",
        "glob",
        "jsdom",
        "lerna",
        "lodash-es",
        "match-sorter",
        "null-loader",
        "react",
        "react-dom",
        "react-router",
        "react-shadow",
        "react-toastify",
        "pnpm",
        "textarea-caret",
        "tsup",
        "typescript",
        "playwright",
        "webpack",
        "zod",
        "/^@babel//",
        "/^@biomejs//",
        "/^@playwright//",
        "/^@radix-ui//",
        "/^@rollup//",
        "/^@testing-library//",
        "/^@types//",
        "/^@vitest//",
        "/^prettier/",
        "/^vitest/",
        "/^stylelint/"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    }
  ]
}
