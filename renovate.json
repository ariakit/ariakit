{
  "extends": ["config:recommended"],
  "minimumReleaseAge": "7 days",
  "semanticCommits": "disabled",
  "packageRules": [
    {
      "matchFileNames": ["website/package.json"],
      "enabled": false
    },
    {
      "matchPackageNames": ["tailwindcss"],
      "matchCurrentVersion": "/^3\\./",
      "enabled": false
    },
    {
      "groupName": "unified",
      "matchPackageNames": [
        "/hast/",
        "/rehype/",
        "/remark/",
        "/unified/",
        "/unist/",
        "/react-markdown/"
      ]
    },
    {
      "groupName": "clerk",
      "matchPackageNames": ["/^@clerk\\//"]
    },
    {
      "groupName": "stripe",
      "matchPackageNames": ["stripe", "/^@stripe/"]
    },
    {
      "groupName": "testing-library",
      "matchPackageNames": ["/^@testing-library/"]
    },
    {
      "groupName": "radix",
      "matchPackageNames": ["/^@radix-ui/"]
    },
    {
      "groupName": "vite",
      "matchPackageNames": ["vite", "/^@vitejs/"]
    },
    {
      "groupName": "oxc",
      "matchPackageNames": ["/^oxlint/", "/^oxfmt/"]
    },
    {
      "matchPackageNames": ["astro"],
      "matchCurrentVersion": "/^5\\./",
      "allowedVersions": "/^5\\./"
    },
    {
      "matchPackageNames": ["@astrojs/cloudflare"],
      "matchCurrentVersion": "/^12\\./",
      "allowedVersions": "/^12\\./"
    },
    {
      "matchPackageNames": ["lint-staged", "vite", "/^@vitejs/"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchPackageNames": [
        "@astrojs/check",
        "@wordpress/components",
        "cross-env",
        "cross-spawn",
        "dotenv",
        "motion",
        "fs-extra",
        "glob",
        "jsdom",
        "lodash-es",
        "match-sorter",
        "null-loader",
        "react",
        "react-dom",
        "react-router",
        "react-shadow",
        "react-toastify",
        "pnpm",
        "textarea-caret",
        "tsup",
        "typescript",
        "playwright",
        "webpack",
        "zod",
        "/^@babel//",
        "/^@playwright//",
        "/^@radix-ui//",
        "/^@rollup//",
        "/^@testing-library//",
        "/^@types//",
        "/^@vitest//",
        "/^oxlint/",
        "/^oxfmt/",
        "/^prettier/",
        "/^vitest/",
        "/^stylelint/"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    }
  ]
}
