{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "helpers:pinGitHubActionDigests"],
  "minimumReleaseAge": "3 days",
  "semanticCommits": "disabled",
  "postUpdateOptions": ["pnpmDedupe"],
  "ignorePaths": [
    "**/node_modules/**",
    "**/bower_components/**",
    "**/vendor/**",
    "**/__tests__/**",
    "**/test/**",
    "**/tests/**",
    "**/__fixtures__/**"
  ],
  "packageRules": [
    {
      "matchFileNames": ["website/package.json"],
      "enabled": false
    },
    {
      "matchFileNames": ["package.json"],
      "matchPackageNames": ["postcss"],
      "enabled": false
    },
    {
      "matchFileNames": ["app/package.json"],
      "matchPackageNames": ["vite"],
      "allowedVersions": "/^8\\./"
    },
    {
      "matchPackageNames": ["tailwindcss"],
      "matchCurrentVersion": "/^3\\./",
      "enabled": false
    },
    {
      "groupName": "unified",
      "matchPackageNames": [
        "/hast/",
        "/rehype/",
        "/remark/",
        "/unified/",
        "/unist/"
      ]
    },
    {
      "groupName": "astro",
      "matchPackageNames": ["astro", "/^@astrojs\\//"]
    },
    {
      "groupName": "changesets",
      "matchPackageNames": ["/^@changesets\\//"]
    },
    {
      "groupName": "clerk",
      "matchPackageNames": ["/^@clerk\\//"]
    },
    {
      "groupName": "stripe",
      "matchPackageNames": ["stripe", "/^@stripe/"]
    },
    {
      "groupName": "testing-library",
      "matchPackageNames": ["/^@testing-library/"]
    },
    {
      "groupName": "radix",
      "matchPackageNames": ["/^@radix-ui/"]
    },
    {
      "groupName": "react",
      "matchPackageNames": [
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom"
      ]
    },
    {
      "groupName": "vite",
      "matchPackageNames": ["vite", "/^@vitejs/"]
    },
    {
      "groupName": "oxc",
      "matchPackageNames": ["/^oxlint/", "/^oxfmt/"]
    },
    {
      "matchPackageNames": ["@types/node"],
      "allowedVersions": "/^24\\./"
    },
    {
      "matchPackageNames": ["lint-staged", "vite", "/^@vitejs/"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchPackageNames": [
        "@astrojs/check",
        "@axe-core/playwright",
        "@wordpress/components",
        "cross-env",
        "cross-spawn",
        "motion",
        "fs-extra",
        "glob",
        "happy-dom",
        "lodash-es",
        "match-sorter",
        "react",
        "react-dom",
        "react-router",
        "react-shadow",
        "react-toastify",
        "rolldown",
        "rolldown-plugin-dts",
        "pnpm",
        "textarea-caret",
        "tsup",
        "typescript",
        "playwright",
        "zod",
        "/^@playwright//",
        "/^@radix-ui//",
        "/^@testing-library//",
        "/^@types//",
        "/^@vitest//",
        "/^oxlint/",
        "/^oxfmt/",
        "/^prettier/",
        "/^vitest/",
        "/^stylelint/"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["actions/**"],
      "pinDigests": false
    }
  ]
}
