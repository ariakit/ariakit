{
  "extends": ["config:recommended"],
  "semanticCommits": "disabled",
  "packageRules": [
    {
      "matchPackageNames": ["shiki"],
      "matchCurrentVersion": "/^1\\./",
      "allowedVersions": "/^1\\./"
    },
    {
      "matchPackageNames": ["tailwindcss"],
      "matchCurrentVersion": "/^3\\./",
      "enabled": false
    },
    {
      "groupName": "unified",
      "matchPackageNames": [
        "/hast/",
        "/rehype/",
        "/remark/",
        "/unified/",
        "/unist/",
        "/react-markdown/"
      ]
    },
    {
      "groupName": "clerk",
      "matchPackageNames": ["/clerk/"]
    },
    {
      "matchFileNames": ["website/package.json"],
      "matchPackageNames": ["stripe", "/^@stripe\\//"],
      "enabled": false
    },
    {
      "groupName": "stripe",
      "matchPackageNames": ["stripe", "/^@stripe\\//"]
    },
    {
      "groupName": "monaco",
      "matchPackageNames": ["/monaco/"]
    },
    {
      "groupName": "testing-library",
      "matchPackageNames": ["/@testing-library//"]
    },
    {
      "groupName": "radix",
      "matchPackageNames": ["/@radix-ui//"]
    },
    {
      "groupName": "vite",
      "matchPackageNames": ["vite", "/^@vitejs\\//"]
    },
    {
      "matchPackageNames": ["lint-staged"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchPackageNames": [
        "@wordpress/components",
        "cross-env",
        "cross-spawn",
        "dotenv",
        "framer-motion",
        "fs-extra",
        "glob",
        "jsdom",
        "lerna",
        "lodash-es",
        "match-sorter",
        "null-loader",
        "react",
        "react-dom",
        "react-router",
        "react-shadow",
        "react-toastify",
        "textarea-caret",
        "tsup",
        "typescript",
        "webpack",
        "zod",
        "/^@babel//",
        "/^@biomejs//",
        "/^@playwright//",
        "/^@radix-ui//",
        "/^@rollup//",
        "/^@testing-library//",
        "/^@types//",
        "/^@vitest//",
        "/^prettier/",
        "/^vitest/",
        "/^stylelint/"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    }
  ]
}
