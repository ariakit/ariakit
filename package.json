{
  "name": "root",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "start": "pnpm -F website start",
    "react17": "pnpm add -w react@17 react-dom@17 @testing-library/react@12 @testing-library/dom@8 && pnpm -F @ariakit/react -F @ariakit/react-core -F @ariakit/test add react@17 react-dom@17 @testing-library/react@12 @testing-library/dom@8",
    "reactnext": "pnpm add -w react@next react-dom@next && pnpm -F @ariakit/react -F @ariakit/react-core -F @ariakit/test add react@next react-dom@next",
    "dev-package-json": "node scripts/build/package-json-dev.js",
    "dev": "conc -r 'pnpm:dev-package-json' 'pnpm -F website run dev'",
    "dev-lite": "cross-env DISABLE_SHIKI=true pnpm run dev",
    "dev-site": "conc -r 'pnpm -F site run dev' 'pnpm -F nextjs run dev'",
    "dev-site-lite": "cross-env DISABLE_SYNTAX_HIGHLIGHTING=true pnpm run dev-site",
    "build-site": "pnpm -F nextjs run build-worker && pnpm -F site run build",
    "build-site-lite": "pnpm -F nextjs run build-worker && pnpm -F site run build-lite",
    "preview-site": "conc -r 'pnpm -F site run preview' 'pnpm -F nextjs run preview'",
    "preview-site-lite": "cross-env DISABLE_REFERENCE_LINKS=true pnpm run preview-site",
    "generate-images": "playwright test -u -c generate-images.config.ts",
    "test": "vitest",
    "test-solid": "ARIAKIT_TEST_LOADER=solid vitest",
    "test-watch": "vitest watch",
    "test-react17": "pnpm run react17 && pnpm test; git checkout package.json pnpm-lock.yaml packages/*/package.json && pnpm install",
    "test-reactnext": "pnpm run reactnext && pnpm test; git checkout package.json pnpm-lock.yaml packages/*/package.json && pnpm install",
    "playwright": "playwright test",
    "test-browser": "playwright test --project=chrome --project=safari --project=firefox",
    "test-browser-solid": "ARIAKIT_TEST_LOADER=solid playwright test --project=chrome --project=safari --project=firefox",
    "test-browser-headed": "playwright test --project=chrome --project=safari --project=firefox --headed",
    "test-browser-debug": "playwright test --project=chrome --project=safari --project=firefox --ui",
    "test-chrome": "playwright test --project=chrome",
    "test-chrome-headed": "playwright test --project=chrome --headed",
    "test-chrome-debug": "playwright test --project=chrome --ui",
    "test-firefox": "playwright test --project=firefox",
    "test-firefox-headed": "playwright test --project=firefox --headed",
    "test-firefox-debug": "playwright test --project=firefox --ui",
    "test-safari": "playwright test --project=safari",
    "test-safari-headed": "playwright test --project=safari --headed",
    "test-safari-debug": "playwright test --project=safari --ui",
    "test-plus": "playwright test --project=plus --workers=1",
    "test-plus-headed": "playwright test --project=plus --workers=1 --headed",
    "test-plus-debug": "playwright test --project=plus --workers=1 --ui",
    "test-mobile": "playwright test --project=ios --project=android",
    "test-mobile-headed": "playwright test --project=ios --project=android --headed",
    "test-mobile-debug": "playwright test --project=ios --project=android --ui",
    "test-ios": "playwright test --project=ios",
    "test-ios-headed": "playwright test --project=ios --headed",
    "test-ios-debug": "playwright test --project=ios --ui",
    "test-android": "playwright test --project=android",
    "test-android-headed": "playwright test --project=android --headed",
    "test-android-debug": "playwright test --project=android --ui",
    "coverage": "pnpm test -- --coverage",
    "postcoverage": "open-cli coverage/index.html",
    "lint": "biome check",
    "lint-fix": "biome check --write",
    "lint-css": "stylelint '**/*.css' --ignore-path .gitignore",
    "tsc": "conc -r 'tsc' 'pnpm -F site run tsc' 'pnpm -F nextjs run tsc' 'pnpm -F \"./templates/*\" run tsc' 'tsc -p tsconfig.solid.json'",
    "tsc-clean": "tsc --build --clean",
    "build": "pnpm -F \"@ariakit/*\" run build",
    "build-website": "pnpm -F website run build",
    "build-website-lite": "cross-env DISABLE_SHIKI=true pnpm run build-website",
    "clean": "pnpm -r run --if-present clean",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --lockfile-only --ignore-scripts",
    "publish": "pnpm run build && changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "package.json": [
      "pnpm -r run --if-present clean",
      "biome check --no-errors-on-unmatched --write"
    ],
    "*.{js,ts,tsx,json}": "biome check --no-errors-on-unmatched --write"
  },
  "pnpm": {
    "overrides": {
      "@wordpress/components>@ariakit/react": "workspace:*"
    },
    "patchedDependencies": {
      "@changesets/apply-release-plan@7.1.0": "patches/@changesets__apply-release-plan@7.1.0.patch"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "dependencies": {
    "@ariakit/core": "workspace:*",
    "@ariakit/react": "workspace:*",
    "@ariakit/react-core": "workspace:*",
    "@ariakit/solid": "workspace:*",
    "@ariakit/solid-core": "workspace:*",
    "@ariakit/tailwind": "workspace:*",
    "@ariakit/test": "workspace:*",
    "@astrojs/mdx": "4.3.14",
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.0",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@babel/types": "7.29.0",
    "@biomejs/biome": "2.4.7",
    "@changesets/cli": "2.30.0",
    "@fontsource-variable/inter": "5.2.8",
    "@playwright/test": "1.56.1",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-select": "2.2.6",
    "@stackblitz/sdk": "1.11.0",
    "@stripe/react-stripe-js": "3.10.0",
    "@stripe/stripe-js": "6.1.0",
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/react-query": "5.90.21",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/babel__core": "7.20.5",
    "@types/canvas-confetti": "1.9.0",
    "@types/cross-spawn": "6.0.6",
    "@types/fs-extra": "11.0.4",
    "@types/lodash": "4.17.24",
    "@types/lodash-es": "4.17.12",
    "@types/marked": "5.0.2",
    "@types/node": "24.12.0",
    "@types/postcss-import": "14.0.3",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@types/textarea-caret": "3.0.4",
    "@types/use-sync-external-store": "0.0.6",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.0",
    "@vizzly-testing/cli": "0.29.6",
    "@wordpress/components": "32.3.0",
    "astro": "5.18.1",
    "autoprefixer": "10.4.27",
    "babel-loader": "10.1.1",
    "babel-plugin-transform-rewrite-imports": "1.5.4",
    "babel-preset-solid": "1.9.10",
    "canvas-confetti": "1.9.4",
    "chalk": "5.6.2",
    "chokidar": "5.0.0",
    "clsx": "2.1.1",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "cross-spawn": "7.0.6",
    "date-fns": "4.1.0",
    "diff": "8.0.3",
    "dotenv": "17.3.1",
    "esbuild-plugin-solid": "0.6.0",
    "fast-fuzzy": "1.12.0",
    "framer-motion": "11.18.2",
    "fs-extra": "11.3.4",
    "glob": "13.0.6",
