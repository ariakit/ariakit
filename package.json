{
  "name": "root",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "pnpm -F website start",
    "dev-package-json": "node scripts/build/package-json-dev.js",
    "dev": "conc -r 'pnpm:dev-package-json' 'pnpm -F website run dev'",
    "dev-lite": "cross-env DISABLE_SHIKI=true pnpm run dev",
    "dev-app": "ariakit dev",
    "dev-app-lite": "cross-env DISABLE_SYNTAX_HIGHLIGHTING=true pnpm run dev-app",
    "build-app": "pnpm -F nextjs run build-worker && pnpm -F app run build",
    "build-app-lite": "pnpm -F nextjs run build-worker && pnpm -F app run build-lite",
    "preview-app": "conc -r 'pnpm -F app run preview' 'pnpm -F nextjs run preview'",
    "preview-app-lite": "cross-env DISABLE_REFERENCE_LINKS=true pnpm run preview-app",
    "generate-images": "pnpm run playwright -u -c generate-images.config.ts",
    "react18": "ariakit react18",
    "test": "vitest",
    "test-react-18": "pnpm react18 test",
    "test-solid": "ARIAKIT_TEST_LOADER=solid vitest",
    "test-watch": "vitest watch",
    "playwright": "playwright test",
    "test-browser": "pnpm run playwright --project=chrome --project=safari --project=firefox",
    "test-browser-solid": "cross-env ARIAKIT_TEST_LOADER=solid pnpm run playwright --project=chrome --project=safari --project=firefox",
    "test-browser-headed": "pnpm run playwright --project=chrome --project=safari --project=firefox --headed",
    "test-browser-debug": "pnpm run playwright --project=chrome --project=safari --project=firefox --ui",
    "test-chrome": "pnpm run playwright --project=chrome",
    "test-chrome-headed": "pnpm run playwright --project=chrome --headed",
    "test-chrome-debug": "pnpm run playwright --project=chrome --ui",
    "test-firefox": "pnpm run playwright --project=firefox",
    "test-firefox-headed": "pnpm run playwright --project=firefox --headed",
    "test-firefox-debug": "pnpm run playwright --project=firefox --ui",
    "test-safari": "pnpm run playwright --project=safari",
    "test-safari-headed": "pnpm run playwright --project=safari --headed",
    "test-safari-debug": "pnpm run playwright --project=safari --ui",
    "test-plus": "pnpm run playwright --project=plus --workers=1",
    "test-plus-headed": "pnpm run playwright --project=plus --workers=1 --headed",
    "test-plus-debug": "pnpm run playwright --project=plus --workers=1 --ui",
    "test-mobile": "pnpm run playwright --project=ios --project=android",
    "test-mobile-headed": "pnpm run playwright --project=ios --project=android --headed",
    "test-mobile-debug": "pnpm run playwright --project=ios --project=android --ui",
    "test-ios": "pnpm run playwright --project=ios",
    "test-ios-headed": "pnpm run playwright --project=ios --headed",
    "test-ios-debug": "pnpm run playwright --project=ios --ui",
    "test-android": "pnpm run playwright --project=android",
    "test-android-headed": "pnpm run playwright --project=android --headed",
    "test-android-debug": "pnpm run playwright --project=android --ui",
    "coverage": "pnpm test --coverage",
    "postcoverage": "open-cli coverage/index.html",
    "lint": "oxlint --disable-nested-config && oxfmt --check",
    "lint-fix": "oxlint --disable-nested-config --fix && oxfmt",
    "lint-css": "stylelint '**/*.css' --ignore-path .gitignore",
    "wrangler-types": "pnpm -F app run wrangler-types",
    "tsc": "pnpm -F app run check && tsc -b",
    "tsc-clean": "tsc -b --clean",
    "build": "pnpm -F \"@ariakit/*\" run build",
    "build-website": "pnpm -F website run build",
    "build-website-lite": "cross-env DISABLE_SHIKI=true pnpm run build-website",
    "clean": "pnpm -r run --if-present clean",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --lockfile-only --ignore-scripts",
    "publish": "pnpm run build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@ariakit/components": "workspace:*",
    "@ariakit/react": "workspace:*",
    "@ariakit/react-components": "workspace:*",
    "@ariakit/react-store": "workspace:*",
    "@ariakit/react-utils": "workspace:*",
    "@ariakit/scripts": "workspace:*",
    "@ariakit/solid": "workspace:*",
    "@ariakit/solid-components": "workspace:*",
    "@ariakit/solid-store": "workspace:*",
    "@ariakit/solid-utils": "workspace:*",
    "@ariakit/store": "workspace:*",
    "@ariakit/tailwind": "workspace:*",
    "@ariakit/test": "workspace:*",
    "@ariakit/utils": "workspace:*",
    "@changesets/apply-release-plan": "7.1.1",
    "@changesets/cli": "2.31.0",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/cross-spawn": "6.0.6",
    "@types/fs-extra": "11.0.4",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.7",
    "autoprefixer": "10.5.0",
    "chalk": "5.6.2",
    "chokidar": "5.0.0",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "cross-spawn": "7.0.6",
    "esbuild-plugin-solid": "0.6.0",
    "fs-extra": "11.3.5",
    "glob": "13.0.6",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.5",
    "next": "16.2.6",
    "open-cli": "9.0.0",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "oxlint-tsgolint": "0.23.0",
    "postcss": "8.5.8",
    "postcss-import": "16.1.1",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "rimraf": "6.1.3",
    "solid-js": "1.9.13",
    "stylelint": "17.12.0",
    "stylelint-config-standard": "40.0.0",
    "tailwindcss": "4.3.0",
    "tailwindcss-animate": "1.0.7",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vite-plugin-solid": "2.11.12",
    "vitest": "4.1.7",
    "vitest-fail-on-console": "0.10.1",
    "wrangler": "4.94.0"
  },
  "lint-staged": {
    "package.json": "pnpm -r run --if-present clean",
    "*.{js,ts,tsx,md,mdx,json}": [
      "oxlint --disable-nested-config --fix --no-error-on-unmatched-pattern",
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "packageManager": "pnpm@11.2.2"
}
