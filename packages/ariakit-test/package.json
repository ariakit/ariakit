    "directory": "packages/ariakit-test"
  },
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "ariakit build --update-exports",
    "clean": "ariakit build --clean"
  },
  "dependencies": {
    "@ariakit/utils": "workspace:*",
