{
  "name": "@ariakit/test",
  "version": "0.6.0",
  "description": "Ariakit test utils",
  "keywords": [
    "ariakit",
    "react"
  ],
  "homepage": "https://ariakit.com",
  "license": "MIT",
  "author": {
    "name": "Diego Haz",
    "email": "hazdiego@gmail.com",
    "url": "https://github.com/diegohaz"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ariakit/ariakit.git",
    "directory": "packages/ariakit-test"
  },
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "ariakit build",
    "clean": "ariakit clean",
    "docs": "ariakit docs --write && pnpm run docs-react && pnpm run docs-playwright",
    "docs-react": "ariakit docs --write --entry src/react.tsx --marker react --heading 'React API reference' --exclude src/index.ts",
    "docs-playwright": "ariakit docs --write --entry src/playwright.ts --marker playwright --heading 'Playwright API reference' --exclude @playwright/test"
  },
  "dependencies": {
    "@ariakit/utils": "workspace:*",
    "@testing-library/dom": "^8.0.0 || ^9.0.0 || ^10.0.0"
  },
  "devDependencies": {
    "@ariakit/scripts": "workspace:*",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "peerDependencies": {
    "@playwright/test": "^1.27.0",
    "@testing-library/react": "^13.0.0 || ^14.0.0 || ^15.0.0 || ^16.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    },
    "@testing-library/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./blur": {
      "types": "./dist/blur.d.ts",
      "import": "./dist/blur.js"
    },
    "./click": {
      "types": "./dist/click.d.ts",
      "import": "./dist/click.js"
    },
    "./dispatch": {
      "types": "./dist/dispatch.d.ts",
      "import": "./dist/dispatch.js"
    },
    "./focus": {
      "types": "./dist/focus.d.ts",
      "import": "./dist/focus.js"
    },
    "./hover": {
      "types": "./dist/hover.d.ts",
      "import": "./dist/hover.js"
    },
    "./mouse-down": {
      "types": "./dist/mouse-down.d.ts",
      "import": "./dist/mouse-down.js"
    },
    "./mouse-up": {
      "types": "./dist/mouse-up.d.ts",
      "import": "./dist/mouse-up.js"
    },
    "./playwright": {
      "types": "./dist/playwright.d.ts",
      "import": "./dist/playwright.js"
    },
    "./press": {
      "types": "./dist/press.d.ts",
      "import": "./dist/press.js"
    },
    "./query": {
      "types": "./dist/query.d.ts",
      "import": "./dist/query.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./select": {
      "types": "./dist/select.d.ts",
      "import": "./dist/select.js"
    },
    "./sleep": {
      "types": "./dist/sleep.d.ts",
      "import": "./dist/sleep.js"
    },
    "./tap": {
      "types": "./dist/tap.d.ts",
      "import": "./dist/tap.js"
    },
    "./type": {
      "types": "./dist/type.d.ts",
      "import": "./dist/type.js"
    },
    "./wait-for": {
      "types": "./dist/wait-for.d.ts",
      "import": "./dist/wait-for.js"
    },
    "./package.json": "./package.json"
  }
}
