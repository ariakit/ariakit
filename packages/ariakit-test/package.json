{
  "name": "@ariakit/test",
  "version": "0.7.1",
  "description": "Ariakit test utils",
  "keywords": [
    "ariakit",
    "react"
  ],
  "homepage": "https://ariakit.com",
  "license": "MIT",
  "author": {
    "name": "Diego Haz",
    "email": "hazdiego@gmail.com",
    "url": "https://github.com/diegohaz"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ariakit/ariakit.git",
    "directory": "packages/ariakit-test"
  },
  "type": "module",
  "scripts": {
    "build": "ariakit build --entries=index,react,playwright",
    "clean": "ariakit clean",
    "docs": "ariakit docs --write && pnpm run docs-react && pnpm run docs-playwright",
    "docs-react": "ariakit docs --write --entry src/react.tsx --marker react --heading 'React API reference' --exclude src/index.ts",
    "docs-playwright": "ariakit docs --write --entry src/playwright.ts --marker playwright --heading 'Playwright API reference' --exclude @playwright/test"
  },
  "dependencies": {
    "@ariakit/utils": "workspace:*",
    "@testing-library/dom": "^8.0.0 || ^9.0.0 || ^10.0.0"
  },
  "devDependencies": {
    "@ariakit/scripts": "workspace:*",
    "@playwright/test": "1.62.0-alpha-2026-07-17",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "peerDependencies": {
    "@playwright/test": "^1.27.0",
    "@testing-library/react": "^13.0.0 || ^14.0.0 || ^15.0.0 || ^16.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    },
    "@testing-library/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "exports": {
    ".": "./src/index.ts",
    "./playwright": "./src/playwright.ts",
    "./react": "./src/react.tsx",
    "./package.json": "./package.json"
  }
}
