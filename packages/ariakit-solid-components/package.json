{
  "name": "@ariakit/solid-components",
  "version": "0.1.1",
  "description": "Ariakit Solid components",
  "keywords": [
    "ariakit",
    "solid",
    "components"
  ],
  "homepage": "https://ariakit.com",
  "license": "MIT",
  "author": {
    "name": "Dani Guardiola",
    "email": "hi@daniguardio.la",
